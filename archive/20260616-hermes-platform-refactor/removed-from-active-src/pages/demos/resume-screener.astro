  function calculateROI() {
    const resumes = parseInt(document.getElementById('resumes-month').value) || 0;
    const hourlyRate = parseInt(document.getElementById('hourly-rate').value) || 0;
    const timePerResume = parseInt(document.getElementById('time-per-resume').value) || 0;
    const teamSize = parseInt(document.getElementById('team-size').value) || 0;
    
    // Calculate savings (assuming 80% time reduction)
    const timeReduction = 0.8;
    const timeSavedPerResume = (timePerResume * timeReduction) / 60; // Convert to hours
    const monthlySavings = resumes * timeSavedPerResume * hourlyRate;
    const annualSavings = monthlySavings * 12;
    const implementationCost = 10000; // Estimated
    const paybackPeriod = implementationCost / monthlySavings;
    
    document.getElementById('monthly-savings').textContent = '$' + monthlySavings.toLocaleString();
    document.getElementById('annual-savings').textContent = '$' + annualSavings.toLocaleString();
    document.getElementById('payback-period').textContent = paybackPeriod.toFixed(1);
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', function() {
