  function showDetailedAnalysis(index) {
    const candidate = candidatesData[index];
    
    // Show detailed analysis panel
    const panel = document.getElementById('detailed-analysis');
    panel.classList.remove('hidden');
    panel.style.display = 'grid';
    panel.scrollIntoView({ behavior: 'smooth' });
    
    // Populate skills
    const skillsContainer = document.getElementById('skills-detailed');
