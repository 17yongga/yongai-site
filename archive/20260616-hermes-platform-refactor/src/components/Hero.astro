---
export interface Props {
  title?: string;
  subtitle?: string;
  showBadge?: boolean;
  showButtons?: boolean;
  showStats?: boolean;
  badgeText?: string;
  customContent?: boolean;
}

const {
  showButtons = true,
  showStats = true,
  badgeText = "Now accepting Q2 2026 clients",
  customContent = false
} = Astro.props;
---

<header class="relative min-h-screen flex items-center overflow-hidden bg-[var(--color-bg-primary)]" id="hero">

  <!-- Subtle dot grid background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="heroDots" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="rgba(0,0,0,0.06)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#heroDots)"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
    {customContent ? (
      <slot />
    ) : (
      <div class="grid lg:grid-cols-[1fr_0.9fr] gap-16 lg:gap-20 items-center min-h-screen py-32">

        <!-- ── Left: Text content ── -->
        <div>
          <!-- Small overline -->
          <p class="text-sm font-semibold text-[#C2410C] uppercase tracking-widest mb-6">
            YongAI — AI Automation Consulting
          </p>

          <!-- Headline -->
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight text-[#1C1C1E] mb-6">
            Your best people<br>
            deserve better<br>
            <span class="text-[#C2410C]">work.</span>
          </h1>

          <!-- Subtitle -->
          <p class="text-xl text-[#64748B] max-w-xl leading-relaxed mb-10">
            AI automation for law firms and recruiting agencies. Audit your workflows, build the right automations, and get measurable ROI — without the enterprise price tag.
          </p>

          <!-- CTAs -->
          {showButtons && (
            <div class="flex flex-col sm:flex-row gap-4 items-start mb-14">
              <button
                onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;"
                class="btn-primary text-base"
              >
                Book a Free Strategy Call
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>

              <a href="/demos/resume-screener" class="btn-secondary text-base">
                See a Live Demo
              </a>
            </div>
          )}

          <!-- Stats -->
          {showStats && (
            <div class="flex flex-wrap gap-10">
              <div>
                <div class="text-3xl font-black text-[#1C1C1E]">6+</div>
                <div class="text-sm text-[#64748B] mt-0.5">Years enterprise consulting</div>
              </div>
              <div class="w-px bg-[rgba(0,0,0,0.1)] self-stretch hidden sm:block"></div>
              <div>
                <div class="text-3xl font-black text-[#1C1C1E]">30+</div>
                <div class="text-sm text-[#64748B] mt-0.5">Enterprise workshops led</div>
              </div>
              <div class="w-px bg-[rgba(0,0,0,0.1)] self-stretch hidden sm:block"></div>
              <div>
                <div class="text-3xl font-black text-[#1C1C1E]">2 wk</div>
                <div class="text-sm text-[#64748B] mt-0.5">From kickoff to first results</div>
              </div>
            </div>
          )}
        </div>

        <!-- ── Right: Animated demo frame ── -->
        <div class="relative hidden lg:flex items-center justify-center">

          <!-- Availability badge (top left) -->
          <div class="frame-badge-reveal absolute -top-6 left-0 z-20 bg-white border border-[rgba(0,0,0,0.08)] rounded-full px-4 py-2 shadow-sm flex items-center gap-2 text-sm font-medium text-[#1C1C1E]">
            <span class="w-2 h-2 rounded-full bg-[#059669] pulse-dot inline-block"></span>
            {badgeText}
          </div>

          <!-- Main frame card (floats) -->
          <div class="float-card w-full max-w-md bg-white rounded-2xl shadow-[0_8px_40px_rgba(0,0,0,0.10)] border border-[rgba(0,0,0,0.07)] overflow-hidden">

            <!-- Frame header bar -->
            <div class="flex items-center gap-2.5 px-5 py-4 border-b border-[rgba(0,0,0,0.07)] bg-[#F3F2EE]">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-[#EF4444] opacity-70"></div>
                <div class="w-3 h-3 rounded-full bg-[#F59E0B] opacity-70"></div>
                <div class="w-3 h-3 rounded-full bg-[#22C55E] opacity-70"></div>
              </div>
              <div class="flex-1 flex items-center justify-between ml-1">
                <span class="text-xs font-semibold text-[#64748B] tracking-wide">YongAI Automation Suite</span>
                <span class="flex items-center gap-1.5 text-xs text-[#059669] font-medium">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#059669] pulse-dot inline-block"></span>
                  2 live · 1 deploying
                </span>
              </div>
            </div>

            <!-- Dot-grid inner background -->
            <div class="relative p-5 bg-[#F3F2EE]" style="background-image: radial-gradient(circle, rgba(0,0,0,0.07) 1px, transparent 1px); background-size: 20px 20px;">

              <!-- Automation items -->
              <div class="space-y-3 mb-5">

                <!-- Item 1: Live automation -->
                <div class="frame-item-1 flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3.5 border border-[rgba(0,0,0,0.07)] shadow-sm">
                  <span class="frame-check">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <polyline points="2,6 5,9 10,3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-[#1C1C1E]">Contract Review AI</div>
                    <div class="text-xs text-[#059669] font-medium">↑ 14 NDAs reviewed automatically this week</div>
                  </div>
                  <span class="text-xs font-bold text-[#C2410C] whitespace-nowrap">3.8 hrs saved</span>
                </div>

                <!-- Item 2: Live automation -->
                <div class="frame-item-2 flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3.5 border border-[rgba(0,0,0,0.07)] shadow-sm">
                  <span class="frame-check">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <polyline points="2,6 5,9 10,3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-[#1C1C1E]">Client Intake Bot</div>
                    <div class="text-xs text-[#059669] font-medium">↑ 11 after-hours leads captured &amp; qualified</div>
                  </div>
                  <span class="text-xs font-bold text-[#C2410C] whitespace-nowrap">6.1 hrs saved</span>
                </div>

                <!-- Item 3: Deploying -->
                <div class="frame-item-3 flex items-center gap-3 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3.5 border border-[rgba(0,0,0,0.07)] shadow-sm">
                  <span class="frame-spinner"></span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-[#1C1C1E]">Resume Screener</div>
                    <div class="text-xs text-[#64748B]">Deploying automation — live in 2 days</div>
                  </div>
                  <span class="text-xs text-[#94A3B8] whitespace-nowrap">deploying</span>
                </div>
              </div>

              <!-- This month's ROI bar -->
              <div class="mb-4 frame-footer-reveal">
                <div class="flex justify-between text-xs text-[#64748B] mb-1.5">
                  <span class="font-medium">Monthly ROI recovered</span>
                  <span class="font-semibold text-[#059669]">$2,600 this month</span>
                </div>
                <div class="h-1.5 bg-[rgba(0,0,0,0.07)] rounded-full overflow-hidden">
                  <div class="h-full bg-[#C2410C] rounded-full" style="width:67%; animation: progressFill 1.2s ease forwards; animation-delay: 3.0s;"></div>
                </div>
              </div>

              <!-- Summary footer -->
              <div class="frame-footer-reveal flex gap-3">
                <div class="flex-1 bg-[#FFF7ED] border border-[rgba(194,65,12,0.15)] rounded-xl p-3 text-center">
                  <div class="text-xl font-black text-[#C2410C]">2 live</div>
                  <div class="text-xs text-[#64748B]">Automations running 24/7</div>
                </div>
                <div class="flex-1 bg-[#F0FDF4] border border-[rgba(5,150,105,0.15)] rounded-xl p-3 text-center">
                  <div class="text-xl font-black text-[#059669]">10 hrs</div>
                  <div class="text-xs text-[#64748B]">Freed up every week</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating value card (bottom left) -->
          <div class="frame-badge-reveal absolute -bottom-6 -left-4 bg-[#C2410C] text-white rounded-2xl px-5 py-4 shadow-lg">
            <div class="text-xs font-semibold opacity-75 mb-0.5">Projected Annual Value</div>
            <div class="text-2xl font-black">$31K+ saved</div>
          </div>

        </div>

      </div>
    )}
  </div>
</header>
