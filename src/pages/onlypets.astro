---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';

const screens = [
  {
    title: 'Discover the pet feed',
    body: 'Browse posts by diet, vets, food, reviews, travel, training, and more — built around real pet-owner questions.',
    image: '/portfolio/onlypets/home-discovery-feed.png',
  },
  {
    title: 'Message other owners',
    body: 'Follow up after a useful recommendation, coordinate pet playdates, or keep a conversation going after a post.',
    image: '/portfolio/onlypets/messages-inbox.png',
  },
  {
    title: 'Spend Nibbles in the store',
    body: 'OnlyPets has a playful in-app economy for digital items, pet perks, badges, frames, and product discovery.',
    image: '/portfolio/onlypets/store-home.png',
  },
  {
    title: 'Create a pet moment',
    body: 'Compose posts with your pet, a category, and a caption so the feed feels like a useful community, not a generic social app.',
    image: '/portfolio/onlypets/create-post-composer.png',
  },
];

const highlights = [
  ['For pet parents', 'A friendly place to share daily moments, ask questions, review products, and learn from other owners.'],
  ['For pet personalities', 'Each pet can have a profile, posts, messages, subscriptions, items, and a little digital identity.'],
  ['In TestFlight', 'The app has been built and submitted through TestFlight for testing; public App Store launch is not done yet.'],
];
---

<Layout
  title="OnlyPets — Pet social app by YongAI"
  description="OnlyPets is a playful pet social app in TestFlight testing, with pet profiles, posts, messages, a store, and a Nibbles economy."
  ogImage="https://yongai.ca/portfolio/onlypets/home-discovery-feed.png"
>
  <main class="onlypets-page">
    <SiteNav />

    <section class="op-hero">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">OnlyPets / TestFlight testing</p>
        <h1>A social app for pets with personalities.</h1>
        <p>
          OnlyPets is a mobile community for pet owners to share posts, build pet profiles, message other owners, discover pet products, and earn a playful in-app currency called Nibbles.
        </p>
        <div class="hero-actions">
          <a href="#screens" class="button primary">See the app</a>
          <a href="/" class="button secondary">Back to YongAI</a>
        </div>
      </div>
      <div class="phone-stack" aria-label="OnlyPets app preview" data-reveal style="--reveal-delay: 90ms">
        <img class="phone main" src="/portfolio/onlypets/home-discovery-feed.png" alt="OnlyPets home discovery feed screenshot" />
        <img class="phone side" src="/portfolio/onlypets/pet-profile-subscriptions.png" alt="OnlyPets pet profile subscriptions screenshot" />
      </div>
    </section>

    <section class="why-section">
      {highlights.map(([title, body], index) => (
        <article data-reveal style={`--reveal-delay: ${index * 70}ms`}>
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))}
    </section>

    <section class="story-section" data-reveal>
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Pet life is social, useful, and weirdly hard to organize.</h2>
      </div>
      <p>
        Pet owners already trade vet notes, food tips, funny moments, product recommendations, and care routines everywhere. OnlyPets brings that into one playful app: part community feed, part pet profile, part store, and part lightweight pet-owner network.
      </p>
    </section>

    <section id="screens" class="screens-section">
      <div class="section-header" data-reveal>
        <p class="eyebrow">App glance</p>
        <h2>What people can do in OnlyPets.</h2>
      </div>
      <div class="screen-grid">
        {screens.map((screen, index) => (
          <article data-reveal style={`--reveal-delay: ${(index % 2) * 70}ms`}>
            <img src={screen.image} alt={`${screen.title} screenshot`} loading="lazy" />
            <div>
              <h3>{screen.title}</h3>
              <p>{screen.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="status-section" data-reveal>
      <div>
        <p class="eyebrow">Current status</p>
        <h2>Built for testing, not public launch yet.</h2>
      </div>
      <ul>
        <li><strong>Testing phase:</strong> TestFlight build submitted/live for tester review.</li>
        <li><strong>Working surfaces:</strong> feed, profiles, posts, DMs, notifications, store, Nibbles, and digital items.</li>
        <li><strong>Next proof:</strong> physical-device TestFlight feedback, messaging UX retest, and clearer validation from real pet owners.</li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) { margin: 0; background: #FFF7F1; }
  :global(*) { box-sizing: border-box; }
  .onlypets-page {
    --op-brown: #552012;
    --op-rust: #C45425;
    --op-cream: #FFF7F1;
    --op-card: #FFFFFF;
    min-height: 100vh;
    color: var(--op-brown);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at 82% 16%, rgba(196, 84, 37, .13), transparent 26rem),
      linear-gradient(180deg, #fff 0%, var(--op-cream) 38%, #FAF8F2 100%);
    overflow-x: hidden;
  }
  .op-hero, .why-section, .story-section, .screens-section, .status-section { width: min(1180px, calc(100% - 48px)); margin-inline: auto; }
  .op-hero { min-height: calc(88vh - 78px); display: grid; grid-template-columns: minmax(0, .95fr) minmax(360px, .85fr); align-items: center; gap: clamp(36px, 5vw, 72px); padding-block: 42px 72px; }
  .eyebrow { margin: 0 0 14px; color: var(--op-rust); font-size: 12px; font-weight: 900; letter-spacing: .18em; text-transform: uppercase; }
  h1, h2, h3, p { margin-top: 0; }
  h1, h2, h3 { font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; }
  h1 { max-width: 760px; margin-bottom: 20px; font-size: clamp(58px, 7vw, 92px); line-height: .96; letter-spacing: -.025em; font-weight: 740; color: var(--op-brown); }
  .hero-copy > p:not(.eyebrow) { max-width: 650px; color: #653226; font-size: clamp(18px, 2vw, 22px); line-height: 1.58; margin-bottom: 28px; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .button { min-height: 48px; padding: 0 21px; display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; text-decoration: none; font-size: 14px; font-weight: 850; transition: transform var(--motion-base) var(--motion-ease), box-shadow var(--motion-base) var(--motion-ease), background-color var(--motion-fast) ease; }
  .button:hover, .button:focus-visible { transform: translateY(-2px); }
  .button:active { transform: translateY(0) scale(.985); }
  .button.primary { background: var(--op-brown); color: #fff; box-shadow: 0 18px 38px rgba(85,32,18,.18); }
  .button.secondary { color: var(--op-brown); background: rgba(255,255,255,.72); border: 1px solid rgba(85,32,18,.16); }
  .phone-stack { position: relative; min-height: 610px; }
  .phone { width: min(54vw, 300px); max-width: 100%; border-radius: 34px; border: 10px solid #fff; box-shadow: 0 28px 70px rgba(85,32,18,.18); background: #fff; }
  .phone.main { position: absolute; right: 26%; top: 0; z-index: 2; }
  .phone.side { position: absolute; right: 0; top: 110px; width: min(45vw, 260px); opacity: .96; }
  .why-section { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 64px; }
  .why-section article, .story-section, .screen-grid article, .status-section { border: 1px solid rgba(85,32,18,.14); border-radius: 22px; background: rgba(255,255,255,.76); box-shadow: 0 18px 48px rgba(85,32,18,.06); transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease), background-color var(--motion-fast) ease; }
  .why-section article:hover, .story-section:hover, .screen-grid article:hover, .status-section:hover { transform: translateY(-3px); border-color: rgba(85,32,18,.25); background: rgba(255,255,255,.92); box-shadow: 0 26px 64px rgba(85,32,18,.10); }
  .why-section article { padding: 24px; min-height: 190px; }
  .why-section h2, .story-section h2, .screens-section h2, .status-section h2 { margin-bottom: 14px; font-size: clamp(30px, 3.8vw, 48px); line-height: 1.06; font-weight: 700; }
  .why-section h2 { font-size: 30px; }
  .why-section p, .story-section p, .screen-grid p, .status-section li { color: #653226; font-size: 16px; line-height: 1.58; }
  .story-section { display: grid; grid-template-columns: .8fr 1fr; gap: 32px; padding: 32px; margin-bottom: 72px; align-items: center; }
  .story-section p { margin: 0; font-size: 18px; }
  .section-header { max-width: 780px; margin-bottom: 28px; }
  .screen-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .screen-grid article { overflow: hidden; display: flex; flex-direction: column; }
  .screen-grid img { width: 100%; aspect-ratio: 9 / 13.5; object-fit: cover; object-position: top; display: block; border-bottom: 1px solid rgba(85,32,18,.12); transition: transform 700ms var(--motion-ease); }
  .screen-grid article:hover img { transform: scale(1.018); }
  .screen-grid div { padding: 20px; }
  .screen-grid h3 { margin-bottom: 10px; font-size: 24px; line-height: 1.05; }
  .screens-section { margin-bottom: 72px; }
  .status-section { display: grid; grid-template-columns: .8fr 1fr; gap: 32px; padding: 32px; margin-bottom: 88px; }
  .status-section ul { margin: 0; padding-left: 20px; display: grid; gap: 14px; }
  .status-section strong { color: var(--op-brown); }
  @media (max-width: 960px) {
    .op-hero, .why-section, .story-section, .status-section { grid-template-columns: 1fr; }
    .op-hero { min-height: 0; }
    .phone-stack { min-height: 540px; }
    .screen-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .op-hero, .why-section, .story-section, .screens-section, .status-section { width: min(100% - 32px, 1180px); }
    h1 { font-size: clamp(46px, 14vw, 62px); }
    .phone-stack { min-height: auto; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .phone.main, .phone.side { position: static; width: 100%; border-width: 6px; border-radius: 24px; }
    .screen-grid { grid-template-columns: 1fr; }
    .story-section, .status-section { padding: 24px; }
  }
  @media (hover: none) {
    .why-section article:hover, .story-section:hover, .screen-grid article:hover, .status-section:hover,
    .screen-grid article:hover img { transform: none; }
  }
</style>
