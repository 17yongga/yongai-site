<script is:inline>
  // Industry workflow data
  const workflowData = {
    legal: {
      name: 'Legal Services',
      totalSavings: 100,  // $100K
      timeReduction: 20,
      roiMonths: 12,
      quickWins: 3,
      chartData: [25, 30, 20, 30, 15]
    },
    recruiting: {
      name: 'Recruiting',
      totalSavings: 50,   // $50K
      timeReduction: 30,
      roiMonths: 6,
      quickWins: 4,
      chartData: [20, 15, 10, 8, 12]
    },
    financial: {
      name: 'Financial Services',
      totalSavings: 200,  // $200K
      timeReduction: 25,
      roiMonths: 12,
      quickWins: 2,
      chartData: [40, 50, 35, 25, 20]
    }
  };

  let currentIndustry = 'legal';

  function initializeIndustryTabs() {
    const tabs = document.querySelectorAll('.industry-tab');
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const industry = this.dataset.industry;
        switchIndustry(industry);
      });
    });
  }

  function switchIndustry(industry) {
    currentIndustry = industry;

    // Update tabs
    document.querySelectorAll('.industry-tab').forEach(tab => {
      const isActive = tab.dataset.industry === industry;
      tab.classList.toggle('active', isActive);
      
      if (isActive) {
        tab.style.background = 'linear-gradient(135deg, var(--color-yong-green), var(--color-yong-green-light))';
        tab.style.color = 'white';
        tab.style.transform = 'translateY(-2px)';
        tab.style.boxShadow = '0 4px 16px rgba(194, 65, 12, 0.4)';
      } else {
        tab.style.background = 'transparent';
        tab.style.color = 'var(--color-text-muted)';
        tab.style.transform = 'translateY(0)';
        tab.style.boxShadow = 'none';
      }
    });

    // Update content
    document.querySelectorAll('.workflow-content').forEach(content => {
      const isActive = content.id === `${industry}-content`;
      content.classList.toggle('active', isActive);
      content.style.display = isActive ? 'block' : 'none';
      
      if (isActive) {
        content.style.animation = 'fadeIn 0.5s ease-out';
      }
    });

    // Update dashboard
    updateDashboard(industry);
    updateChart(industry);
  }

  function initializeWorkflowSteps() {
    const steps = document.querySelectorAll('.workflow-step');
    steps.forEach(step => {
      const header = step.querySelector('.step-header');
      const expandIcon = step.querySelector('.step-expand');
      const content = step.querySelector('.step-content');
      
      header.addEventListener('click', function() {
        const isExpanded = step.classList.contains('expanded');
        
        // Close all other steps
        steps.forEach(otherStep => {
          if (otherStep !== step) {
            otherStep.classList.remove('expanded');
            const otherContent = otherStep.querySelector('.step-content');
            const otherIcon = otherStep.querySelector('.step-expand');
            otherContent.style.display = 'none';
            otherIcon.style.transform = 'rotate(0deg)';
          }
        });
        
        // Toggle current step
        step.classList.toggle('expanded');
        
        if (step.classList.contains('expanded')) {
          content.style.display = 'block';
          content.style.animation = 'slideDown 0.3s ease-out';
          expandIcon.style.transform = 'rotate(180deg)';
        } else {
          content.style.display = 'none';
          expandIcon.style.transform = 'rotate(0deg)';
        }
      });
    });
  }

  function updateDashboard(industry) {
    const data = workflowData[industry];
    
    // Animate counters
    animateCounter('annual-savings', 0, data.totalSavings, '$', 'K');
    animateCounter('time-reduction', 0, data.timeReduction, '', '%');
    animateCounter('months-to-roi', 0, data.roiMonths, '', '');
    animateCounter('quick-wins', 0, data.quickWins, '', '');
  }

  function updateChart(industry) {
    const data = workflowData[industry];
    const maxValue = Math.max(...data.chartData);
    const chartContainer = document.getElementById('savings-chart');
    
    chartContainer.innerHTML = data.chartData.map((value, index) => {
      const height = (value / maxValue) * 80; // Max height 80px
      return `
        <div style="
          height: ${height}px; 
          width: 40px; 
          background: linear-gradient(to top, var(--color-yong-green), var(--color-yong-green-light));
          border-radius: 6px 6px 0 0;
          position: relative;
          transition: height 0.8s ease;
        ">
          <div style="
            position: absolute;
            bottom: -30px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 12px;
            color: var(--color-text-muted);
          ">Step ${index + 1}</div>
        </div>
      `;
    }).join('');
  }

  function animateCounter(elementId, start, end, prefix = '', suffix = '') {
    const element = document.getElementById(elementId);
    if (!element) return;
    
    const duration = 2000;
    const startTime = performance.now();
    
    function updateCounter(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      // Easing function
      const easeOutCubic = 1 - Math.pow(1 - progress, 3);
      const current = start + (end - start) * easeOutCubic;
      
      if (elementId === 'annual-savings') {
        element.textContent = prefix + Math.round(current) + suffix;
      } else {
        element.textContent = prefix + Math.round(current) + suffix;
      }
      
      if (progress < 1) {
        requestAnimationFrame(updateCounter);
      }
    }
    
    requestAnimationFrame(updateCounter);
  }

  // Initialize everything when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    initializeIndustryTabs();
    initializeWorkflowSteps();
    updateDashboard(currentIndustry);
    updateChart(currentIndustry);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

