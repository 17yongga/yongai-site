---
import DemoLayout from '../../layouts/DemoLayout.astro';
import FlowDiagram from '../../components/FlowDiagram.astro';

const title = "AI Workflow Consulting | YongAI";
const description = "Interactive workflow audit demo across Legal, Recruiting, and Financial Services. See our end-to-end consulting methodology with process mapping, pain point analysis, and AI solution recommendations.";
---

<DemoLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="section-label mb-4">AI WORKFLOW CONSULTING</p>
      <h1 class="text-5xl lg:text-7xl font-black mb-6 leading-none text-[#1C1C1E]">
        Every engagement starts here. <br class="hidden lg:block"/>Before we build anything, we map your processes.
      </h1>
      <p class="text-xl lg:text-2xl text-text-muted max-w-3xl mx-auto mb-12 leading-relaxed">
        We don't sell AI tools. We run structured consulting engagements — starting with a deep process audit, then building tailored systems that solve the specific problems we find. The demos on this site are real deliverables from real engagements.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
        <a href="#analysis" class="btn-primary text-lg px-10 py-4">
          See What's Possible
        </a>
        <button 
          onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;" 
          class="btn-secondary text-lg px-10 py-4"
        >
          Book a Discovery Session
        </button>
      </div>
      <!-- Hero Illustration -->
      <div class="max-w-3xl mx-auto mt-8 px-4">
        <img
          src="/illustrations/hero-workflow-audit.svg"
          alt="Workflow Audit illustration"
          class="w-full rounded-2xl shadow-2xl shadow-black/50 border border-[rgba(0,0,0,0.08)]"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Our Approach Section -->
  <section id="approach" class="py-24 bg-[#F4F3EF] border-t border-[rgba(0,0,0,0.06)]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="section-label mb-4">THE METHODOLOGY</p>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-[#1C1C1E]">We don't start with AI. We start with a map.</h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">Most AI projects fail not because the technology doesn't work — but because they automate the wrong things first. Before recommending anything, we need to understand how your team actually works.</p>
      </div>
      
      <!-- Process Flow Diagram -->
      <FlowDiagram 
        steps={[
          {
            id: "discover",
            title: "Discover",
            description: "Map how your team works today",
            icon: "🔍",
            color: "yong-green"
          },
          {
            id: "analyze", 
            title: "Analyze",
            description: "Identify pain points & bottlenecks",
            icon: "📊",
            color: "purple-500"
          },
          {
            id: "prioritize",
            title: "Prioritize", 
            description: "Rank opportunities by impact & effort",
            icon: "🎯",
            color: "blue-500"
          },
          {
            id: "implement",
            title: "Implement",
            description: "Deploy targeted AI solutions", 
            icon: "⚙️",
            color: "info"
          },
          {
            id: "optimize",
            title: "Optimize",
            description: "Monitor, measure & iterate",
            icon: "📈", 
            color: "purple-400"
          }
        ]}
        orientation="horizontal"
      />
    </div>
  </section>

  <!-- Interactive Industry Analysis -->
  <section id="analysis" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="section-label mb-4">INDUSTRY BENCHMARKS</p>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-[#1C1C1E]">Here's what your competitors are already automating.</h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">Select your industry to see the specific workflows where AI creates the biggest impact — with real data on time saved, cost reduced, and ROI timeline.</p>
      </div>
      
      <!-- Industry Tabs -->
      <div class="flex justify-center mb-12 px-4">
        <div class="glassmorphism rounded-2xl p-2 flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
          <button 
            class="industry-tab active px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-sm uppercase tracking-wider transition-all duration-300"
            data-industry="legal"
          >
            Legal Services
          </button>
          <button 
            class="industry-tab px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-sm uppercase tracking-wider transition-all duration-300"
            data-industry="recruiting"
          >
            Recruiting
          </button>
          <button 
            class="industry-tab px-6 py-3 sm:px-8 sm:py-4 rounded-xl font-semibold text-sm uppercase tracking-wider transition-all duration-300"
            data-industry="financial"
          >
            Financial Services
          </button>
        </div>
      </div>
      
      <!-- Workflow Content -->
      <div class="workflow-content active" id="legal-content">
        <div class="space-y-6">
          <!-- Legal Workflow Steps -->
          <div class="workflow-step glassmorphism rounded-2xl overflow-hidden transition-all duration-300 hover:border-info/30">
            <div class="step-header flex items-center justify-between p-6 cursor-pointer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center text-info font-bold">1</div>
                <div>
                  <h3 class="text-xl font-bold">Client Intake & Onboarding</h3>
                  <p class="text-text-muted">Initial client setup and conflict checking</p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right hidden sm:block">
                  <div class="text-2xl font-bold text-info">4 hrs/wk</div>
                  <div class="text-sm text-text-muted">Avg. Time Saved with AI</div>
                </div>
                <div class="step-expand text-text-muted">▼</div>
              </div>
            </div>
            <div class="step-content hidden p-6 pt-0 border-t border-[rgba(0,0,0,0.06)]">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <h4 class="flex items-center gap-3 text-danger font-bold mb-6 bg-danger/10 px-4 py-3 rounded-xl">
                    Where time is being lost
                  </h4>
                  <div class="space-y-4">
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Lawyers spend an avg. 15 minutes just searching for contract starting points
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Conflict checking requires 20 minutes per case
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Fee estimation based on lawyer experience varies 30-40%
                    </div>
                  </div>
                </div>
                <div>
                  <h4 class="flex items-center gap-3 text-yong-green font-bold mb-6 bg-yong-green/10 px-4 py-3 rounded-xl">
                    Where AI creates the most value
                  </h4>
                  <div class="space-y-4">
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Document Processing Automation</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI reads and pulls key info from your intake forms automatically</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">65% of users save 1-5 hrs/week</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Source: MyCase, 2025</span>
                      </div>
                      <span class="text-xs bg-yong-green/20 text-yong-green px-2 py-1 rounded uppercase font-medium">Low Complexity</span>
                    </div>
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Automated Conflict Checking</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI searches firm database + public records for conflicts</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Faster conflict checks</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Reduced manual effort</span>
                      </div>
                      <span class="text-xs bg-warning/20 text-warning px-2 py-1 rounded uppercase font-medium">Medium Complexity</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-6 p-4 bg-info/5 border border-info/20 rounded-lg">
                <p class="text-sm italic text-text-faint">Sources: Thomson Reuters (2025), MyCase Guide to Using AI in Law (2025)</p>
              </div>
            </div>
          </div>
          
          <!-- Legal Research -->
          <div class="workflow-step glassmorphism rounded-2xl overflow-hidden transition-all duration-300 hover:border-info/30">
            <div class="step-header flex items-center justify-between p-6 cursor-pointer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center text-info font-bold">2</div>
                <div>
                  <h3 class="text-xl font-bold">Legal Research</h3>
                  <p class="text-text-muted">Case law search and precedent analysis</p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right hidden sm:block">
                  <div class="text-2xl font-bold text-info">32.5 days</div>
                  <div class="text-sm text-text-muted">Annual Days Saved per Lawyer</div>
                </div>
                <div class="step-expand text-text-muted">▼</div>
              </div>
            </div>
            <div class="step-content hidden p-6 pt-0 border-t border-[rgba(0,0,0,0.06)]">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <h4 class="flex items-center gap-3 text-danger font-bold mb-6 bg-danger/10 px-4 py-3 rounded-xl">
                    Where time is being lost
                  </h4>
                  <div class="space-y-4">
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Legal professionals could save up to 12 hours per week by 2029
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      20% of knowledge worker time is spent searching for information
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Average blended law firm billing rate: $314/hour
                    </div>
                  </div>
                </div>
                <div>
                  <h4 class="flex items-center gap-3 text-yong-green font-bold mb-6 bg-yong-green/10 px-4 py-3 rounded-xl">
                    Where AI creates the most value
                  </h4>
                  <div class="space-y-4">
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">AI Legal Research</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">Search for cases by asking questions in plain English</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Up to 32.5 days/year saved</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Source: Everlaw, 2025</span>
                      </div>
                      <span class="text-xs bg-warning/20 text-warning px-2 py-1 rounded uppercase font-medium">Medium Complexity</span>
                    </div>
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Case Precedent Analysis</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI identifies similar cases and outcome patterns</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">~$100K billable time recovered</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Source: Thomson Reuters, 2024</span>
                      </div>
                      <span class="text-xs bg-danger/20 text-danger px-2 py-1 rounded uppercase font-medium">High Complexity</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-6 p-4 bg-info/5 border border-info/20 rounded-lg">
                <p class="text-sm italic text-text-faint">Sources: Everlaw Ediscovery Innovation Report (2025), Thomson Reuters Future of Professionals (2024)</p>
              </div>
            </div>
          </div>

          <!-- Document Drafting -->
          <div class="workflow-step glassmorphism rounded-2xl overflow-hidden transition-all duration-300 hover:border-info/30">
            <div class="step-header flex items-center justify-between p-6 cursor-pointer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center text-info font-bold">3</div>
                <div>
                  <h3 class="text-xl font-bold">Document Drafting</h3>
                  <p class="text-text-muted">Contract and legal document creation</p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right hidden sm:block">
                  <div class="text-2xl font-bold text-info">1-5 hrs</div>
                  <div class="text-sm text-text-muted">Weekly Time Saved per Lawyer</div>
                </div>
                <div class="step-expand text-text-muted">▼</div>
              </div>
            </div>
            <div class="step-content hidden p-6 pt-0 border-t border-[rgba(0,0,0,0.06)]">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <h4 class="flex items-center gap-3 text-danger font-bold mb-6 bg-danger/10 px-4 py-3 rounded-xl">
                    Where time is being lost
                  </h4>
                  <div class="space-y-4">
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Contract drafting averages 3.2 hours per document
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Template inconsistencies lead to 15% revision rate
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Junior lawyers spend 4 hours/day on routine drafting
                    </div>
                  </div>
                </div>
                <div>
                  <h4 class="flex items-center gap-3 text-yong-green font-bold mb-6 bg-yong-green/10 px-4 py-3 rounded-xl">
                    Where AI creates the most value
                  </h4>
                  <div class="space-y-4">
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">AI Document Assembly</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">Generate contracts from client parameters and case requirements</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">1-5 hrs saved weekly</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Source: MyCase, 2025</span>
                      </div>
                      <span class="text-xs bg-warning/20 text-warning px-2 py-1 rounded uppercase font-medium">Medium Complexity</span>
                    </div>
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Clause Optimization</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI suggests best clauses based on case outcomes</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Consistent clause selection</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Reduced revision cycles</span>
                      </div>
                      <span class="text-xs bg-danger/20 text-danger px-2 py-1 rounded uppercase font-medium">High Complexity</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-6 p-4 bg-info/5 border border-info/20 rounded-lg">
                <p class="text-sm italic text-text-faint">Sources: MyCase (2025), Deloitte Legal Operations Survey (2024)</p>
              </div>
            </div>
          </div>

          <!-- Document Review -->
          <div class="workflow-step glassmorphism rounded-2xl overflow-hidden transition-all duration-300 hover:border-info/30">
            <div class="step-header flex items-center justify-between p-6 cursor-pointer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center text-info font-bold">4</div>
                <div>
                  <h3 class="text-xl font-bold">Document Review</h3>
                  <p class="text-text-muted">Discovery and contract analysis</p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right hidden sm:block">
                  <div class="text-2xl font-bold text-info">~$100K</div>
                  <div class="text-sm text-text-muted">Annual Value per Lawyer (AI-enabled)</div>
                </div>
                <div class="step-expand text-text-muted">▼</div>
              </div>
            </div>
            <div class="step-content hidden p-6 pt-0 border-t border-[rgba(0,0,0,0.06)]">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <h4 class="flex items-center gap-3 text-danger font-bold mb-6 bg-danger/10 px-4 py-3 rounded-xl">
                    Where time is being lost
                  </h4>
                  <div class="space-y-4">
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Discovery review costs $1-3 per document reviewed
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Partners spend 2.5 hours/day on document review
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Error rates in manual review reach 8-12%
                    </div>
                  </div>
                </div>
                <div>
                  <h4 class="flex items-center gap-3 text-yong-green font-bold mb-6 bg-yong-green/10 px-4 py-3 rounded-xl">
                    Where AI creates the most value
                  </h4>
                  <div class="space-y-4">
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">AI Document Review</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI sorts documents by importance, so lawyers focus on what matters</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Significant cost reduction</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">AI-assisted review</span>
                      </div>
                      <span class="text-xs bg-warning/20 text-warning px-2 py-1 rounded uppercase font-medium">Medium Complexity</span>
                    </div>
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Contract Analysis</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI identifies risks and non-standard terms automatically</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Hours freed for high-value work</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">~$100K billable value/yr</span>
                      </div>
                      <span class="text-xs bg-yong-green/20 text-yong-green px-2 py-1 rounded uppercase font-medium">Low Complexity</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-6 p-4 bg-info/5 border border-info/20 rounded-lg">
                <p class="text-sm italic text-text-faint">Source: Thomson Reuters Future of Professionals Report (2024)</p>
              </div>
            </div>
          </div>

          <!-- Time Tracking & Billing -->
          <div class="workflow-step glassmorphism rounded-2xl overflow-hidden transition-all duration-300 hover:border-info/30">
            <div class="step-header flex items-center justify-between p-6 cursor-pointer">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center text-info font-bold">5</div>
                <div>
                  <h3 class="text-xl font-bold">Time Tracking & Billing</h3>
                  <p class="text-text-muted">Revenue capture and client billing</p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right hidden sm:block">
                  <div class="text-2xl font-bold text-info">15%</div>
                  <div class="text-sm text-text-muted">Revenue Typically Lost to Underbilling</div>
                </div>
                <div class="step-expand text-text-muted">▼</div>
              </div>
            </div>
            <div class="step-content hidden p-6 pt-0 border-t border-[rgba(0,0,0,0.06)]">
              <div class="grid lg:grid-cols-2 gap-8">
                <div>
                  <h4 class="flex items-center gap-3 text-danger font-bold mb-6 bg-danger/10 px-4 py-3 rounded-xl">
                    Where time is being lost
                  </h4>
                  <div class="space-y-4">
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Lawyers capture only 85% of billable time
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Time entry takes 15 minutes daily per lawyer
                    </div>
                    <div class="border-l-4 border-l-danger bg-danger/5 p-4 rounded-lg">
                      Billing adjustments average 8% of total fees
                    </div>
                  </div>
                </div>
                <div>
                  <h4 class="flex items-center gap-3 text-yong-green font-bold mb-6 bg-yong-green/10 px-4 py-3 rounded-xl">
                    Where AI creates the most value
                  </h4>
                  <div class="space-y-4">
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Automated Time Capture</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI tracks activities and suggests time entries</p>
                      <div class="flex gap-2 flex-wrap mb-2">
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Improved time capture</span>
                        <span class="text-xs bg-warning/10 text-warning px-2 py-1 rounded">Less revenue leakage</span>
                      </div>
                      <span class="text-xs bg-yong-green/20 text-yong-green px-2 py-1 rounded uppercase font-medium">Low Complexity</span>
                    </div>
                    <div class="glassmorphism border-l-4 border-l-yong-green p-4 rounded-lg">
                      <div class="flex items-center gap-2 mb-2">
                        <span>✨</span>
                        <span class="font-bold text-yong-green">Predictive Billing</span>
                      </div>
                      <p class="text-text-muted text-sm mb-3">AI forecasts case costs based on similar matters</p>
                      <div class="flex gap-2 flex-wrap mb-2">
