---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';

const journey = [
  ['01', 'Stay in the conversation', 'Start a recording, confirm everyone is comfortable, and put the phone down. Cue saves the audio before asking the cloud to do anything.'],
  ['02', 'Find the signal', 'Afterward, Cue shapes the conversation into a brief, decisions, actions, open questions, and a readable transcript.'],
  ['03', 'Move it forward', 'Ask what mattered, check the next step, or return to the exact conversation when the details matter.'],
];
---

<Layout
  title="Cue — Leave the meeting knowing what comes next"
  description="Cue is a private voice meeting assistant in TestFlight that turns conversations into clear debriefs, actions, insights, and next moves."
  ogImage="https://yongai.ca/portfolio/logos/cue-web.png"
>
  <main class="cue-page">
    <SiteNav />

    <section class="hero">
      <div data-reveal>
        <p class="eyebrow">Cue / TestFlight</p>
        <h1>Leave the meeting knowing what comes next.</h1>
        <p class="lead">
          Cue started with a familiar problem: a useful conversation ends, the day moves on, and its decisions disappear into scattered notes. It records the room, builds a practical debrief, and keeps the next move easy to find.
        </p>
        <div class="actions">
          <a href="#flow" class="button primary">See how Cue works</a>
          <a href="mailto:gary.yong@yongai.ca" class="button secondary">Ask about Cue</a>
        </div>
      </div>
      <aside class="debrief-preview" aria-label="Example Cue debrief" data-reveal style="--reveal-delay: 120ms">
        <div class="preview-brand">
          <img src="/portfolio/logos/cue-web.png" alt="Cue app icon" />
          <div><strong>Cue</strong><span>Private TestFlight prototype</span></div>
        </div>
        <p class="preview-kicker">After the conversation</p>
        <h2>The next move stays visible.</h2>
        <div class="next-move">
          <span>Suggested next move</span>
          <strong>Send the follow-up while the context is still fresh.</strong>
        </div>
        <div class="preview-meta"><span>2 actions</span><span>1 open question</span><span>Brief ready</span></div>
      </aside>
    </section>

    <section class="origin" data-reveal>
      <div><p class="eyebrow">The intent</p><h2>Built for the moment after.</h2></div>
      <div class="origin-copy">
        <p>Most meeting tools stop at the transcript. Cue is interested in what follows: what changed, what needs a decision, and what should happen while the context is still useful.</p>
        <p>It is deliberately personal and private first. The goal is not to create another archive of meetings. It is to make each conversation easier to act on.</p>
      </div>
    </section>

    <section id="flow" class="flow-section">
      <div class="section-header" data-reveal><p class="eyebrow">The flow</p><h2>From conversation to a useful next step.</h2></div>
      <div class="journey-grid">
      {journey.map(([number, title, body], index) => (
        <article data-reveal style={`--reveal-delay: ${index * 70}ms`}>
          <span>{number}</span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
      </div>
    </section>

    <section class="status" data-reveal>
      <div><p class="eyebrow">Current status</p><h2>In TestFlight, learning from real use.</h2><p>Cue is working on iPhone today, but it is still a testing product—not a public App Store release.</p></div>
      <div class="status-list">
        <div><span>Working now</span><strong>Recording, long-call transcription, structured debriefs, and Ask.</strong></div>
        <div><span>Testing now</span><strong>Action quality, useful insights, and a simpler conversation flow.</strong></div>
        <div><span>Not yet</span><strong>A public launch or a general-purpose meeting platform.</strong></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) { margin: 0; background: #FAF8F2; }
  :global(*) { box-sizing: border-box; }
  .cue-page { min-height: 100vh; color: #000; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: radial-gradient(circle at 82% 16%, rgba(223,214,197,.38), transparent 25rem), linear-gradient(180deg, #fff 0%, #FAF8F2 52%, #F4F0E7 100%); }
  .hero, .origin, .flow-section, .status { width: min(1120px, calc(100% - 48px)); margin-inline: auto; }
  h1, h2, h3 { font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; margin-top: 0; }
  .eyebrow { margin: 0 0 14px; color: #555; font-size: 12px; font-weight: 850; letter-spacing: .18em; text-transform: uppercase; }
  .hero { min-height: calc(84vh - 78px); display: grid; grid-template-columns: minmax(0,1.08fr) minmax(340px,.72fr); gap: clamp(40px, 6vw, 84px); align-items: center; padding-block: 46px 72px; }
  h1 { max-width: 760px; margin-bottom: 22px; font-size: clamp(54px, 6.2vw, 86px); line-height: .97; letter-spacing: -.025em; }
  .lead { max-width: 660px; margin: 0 0 30px; color: #2F2F2F; font-size: clamp(18px, 1.85vw, 21px); line-height: 1.62; }
  .actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .button { min-height: 48px; padding: 0 21px; display: inline-flex; align-items: center; border-radius: 999px; text-decoration: none; font-size: 14px; font-weight: 850; transition: transform var(--motion-base) var(--motion-ease), box-shadow var(--motion-base) var(--motion-ease), background-color var(--motion-fast) ease; }
  .button:hover, .button:focus-visible { transform: translateY(-2px); }
  .button:active { transform: translateY(0) scale(.985); }
  .button.primary { color: #fff; background: #000; box-shadow: 0 16px 34px rgba(0,0,0,.14); }
  .button.secondary { color: #000; background: rgba(255,255,255,.68); border: 1px solid rgba(0,0,0,.13); }

  .debrief-preview { padding: 24px; border: 1px solid rgba(0,0,0,.12); border-radius: 26px; background: rgba(255,255,255,.82); box-shadow: 0 28px 80px rgba(36,30,23,.10); transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease); }
  .debrief-preview:hover { transform: translateY(-3px); border-color: rgba(0,0,0,.22); box-shadow: 0 34px 88px rgba(36,30,23,.13); }
  .preview-brand { display: flex; align-items: center; gap: 13px; padding-bottom: 20px; border-bottom: 1px solid rgba(0,0,0,.1); }
  .preview-brand img { width: 58px; height: 58px; object-fit: contain; display: block; filter: drop-shadow(0 10px 18px rgba(36,30,23,.10)); }
  .preview-brand div { display: grid; gap: 2px; }
  .preview-brand strong { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 25px; line-height: 1; }
  .preview-brand span, .preview-kicker, .next-move span { color: #625D54; font-size: 11px; font-weight: 820; letter-spacing: .09em; text-transform: uppercase; }
  .preview-kicker { margin: 24px 0 10px; }
  .debrief-preview h2 { margin-bottom: 20px; font-size: clamp(32px, 3.4vw, 44px); line-height: 1.02; }
  .next-move { padding: 18px; border-radius: 17px; color: #fff; background: #0B0C0E; }
  .next-move span { display: block; margin-bottom: 8px; color: rgba(255,255,255,.54); }
  .next-move strong { display: block; font-size: 15px; line-height: 1.45; }
  .preview-meta { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 15px; }
  .preview-meta span { padding: 7px 9px; border: 1px solid rgba(0,0,0,.1); border-radius: 999px; color: #3B3B3B; background: #FAF8F2; font-size: 11px; font-weight: 760; }

  .origin { display: grid; grid-template-columns: .82fr 1.18fr; gap: clamp(34px, 7vw, 96px); align-items: start; padding-block: 76px; border-top: 1px solid rgba(0,0,0,.1); }
  .origin h2, .section-header h2, .status h2 { margin-bottom: 0; font-size: clamp(38px, 4.8vw, 60px); line-height: 1.02; }
  .origin-copy { display: grid; gap: 15px; }
  .origin-copy p { margin: 0; color: #3B3B3B; font-size: 18px; line-height: 1.66; }

  .flow-section { padding-block: 72px; }
  .section-header { max-width: 780px; margin-bottom: 30px; }
  .journey-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .journey-grid article { min-height: 250px; padding: 25px; border: 1px solid rgba(0,0,0,.12); border-radius: 21px; background: rgba(255,255,255,.7); transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease), background-color var(--motion-fast) ease; }
  .journey-grid article:hover { transform: translateY(-3px); border-color: rgba(0,0,0,.22); background: rgba(255,255,255,.94); box-shadow: 0 20px 52px rgba(36,30,23,.08); }
  .journey-grid article > span { display: block; margin-bottom: 48px; color: #625D54; font-size: 12px; font-weight: 820; letter-spacing: .16em; }
  .journey-grid h3 { margin-bottom: 14px; font-size: 29px; line-height: 1.06; }
  .journey-grid p { margin: 0; color: #3B3B3B; line-height: 1.6; }

  .status { display: grid; grid-template-columns: .88fr 1.12fr; gap: clamp(36px, 7vw, 90px); margin-bottom: 88px; padding: 34px; border: 1px solid rgba(0,0,0,.12); border-radius: 24px; color: #fff; background: #0B0C0E; box-shadow: 0 24px 70px rgba(0,0,0,.12); }
  .status .eyebrow { color: rgba(255,255,255,.52); }
  .status h2 { color: #fff; }
  .status > div > p:last-child { margin: 18px 0 0; color: rgba(255,255,255,.66); font-size: 16px; line-height: 1.6; }
  .status-list { border-top: 1px solid rgba(255,255,255,.15); }
  .status-list div { display: grid; grid-template-columns: 105px 1fr; gap: 16px; padding: 17px 0; border-bottom: 1px solid rgba(255,255,255,.15); }
  .status-list span { color: rgba(255,255,255,.5); font-size: 11px; font-weight: 820; letter-spacing: .1em; text-transform: uppercase; }
  .status-list strong { color: rgba(255,255,255,.9); font-size: 14px; line-height: 1.5; }

  @media (max-width: 820px) {
    .hero, .origin, .journey-grid, .status { grid-template-columns: 1fr; }
    .hero { min-height: 0; padding-block: 40px 64px; }
    .debrief-preview { max-width: 520px; }
    .origin { padding-block: 60px; }
  }
  @media (max-width: 560px) {
    .hero, .origin, .flow-section, .status { width: min(100% - 32px, 1120px); }
    .hero { gap: 42px; padding-top: 38px; }
    h1 { font-size: clamp(44px, 12.5vw, 58px); line-height: .99; }
    .lead { font-size: 18px; line-height: 1.62; }
    .actions { display: grid; grid-template-columns: 1fr; }
    .button { justify-content: center; }
    .debrief-preview { padding: 20px; border-radius: 22px; }
    .preview-brand img { width: 52px; height: 52px; }
    .origin { gap: 26px; padding-block: 54px; }
    .origin-copy p { font-size: 17px; }
    .flow-section { padding-block: 54px; }
    .journey-grid article { min-height: 0; }
    .journey-grid article > span { margin-bottom: 30px; }
    .status { gap: 28px; margin-bottom: 64px; padding: 25px; }
    .status-list div { grid-template-columns: 1fr; gap: 7px; }
  }
  @media (hover: none) { .debrief-preview:hover, .journey-grid article:hover { transform: none; } }
</style>
