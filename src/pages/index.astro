---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'YongAI — Hermes Agent Service Platform';
const description = 'YongAI designs and sets up private Hermes Agent operators for founders, consultants, job seekers, creators, and teams that need useful automation with memory, tools, schedules, and approval boundaries.';

const platformPillars = [
  {
    label: 'Messaging-native',
    title: 'Runs where work actually happens',
    body: 'Your agent can operate from Telegram, Discord, Slack, WhatsApp, email, or the terminal instead of sitting in yet another dashboard.'
  },
  {
    label: 'Persistent context',
    title: 'Memory and skills compound over time',
    body: 'Hermes keeps durable preferences, project context, reusable procedures, and operating rules so every session does not start from zero.'
  },
  {
    label: 'Tool-backed execution',
    title: 'Not just answers — completed work',
    body: 'The setup can include file access, web research, GitHub, spreadsheets, reminders, scheduled jobs, browsers, and carefully scoped integrations.'
  },
  {
    label: 'Approval boundaries',
    title: 'Autonomy without cowboy behavior',
    body: 'We define what the agent can do automatically, what it can draft for approval, and what it should never touch without explicit scope.'
  }
];

const setupSteps = [
  ['01', 'Workflow map', 'We pick the recurring work worth automating: briefings, trackers, research, project updates, reminders, inbox triage, job search, or admin.'],
  ['02', 'Hermes build', 'Provider, model, gateway, memory, tools, skills, cron jobs, and safety defaults are configured around the workflow.'],
  ['03', 'Operating handoff', 'You get the rules, examples, prompts, and maintenance notes needed to actually rely on the agent day to day.']
];

const useCases = [
  ['Consultants / PMs', 'Meeting prep, stakeholder follow-ups, weekly status reports, research briefs, decision logs.'],
  ['Founders', 'Competitor monitoring, product changelogs, support digests, investor/update drafts, backlog grooming.'],
  ['Job seekers', 'Role discovery, tracker updates, tailored resume checklists, recruiter follow-ups, interview prep.'],
  ['Creators', 'Source monitoring, voice-note outlines, newsletter research, publishing calendars, sponsor lead tracking.'],
  ['Personal operators', 'Calendar/email digests, travel planning, reminders, gift ideas, life admin, journaling support.'],
  ['Technical teams', 'Repo summaries, issue triage, release checklists, QA notes, lightweight internal tools.']
];

const packages = [
  {
    name: 'Quickstart',
    price: 'CAD $299–$499',
    timeline: 'Same-day setup',
    summary: 'For people who want Hermes installed correctly and one useful workflow running without fighting config files.',
    items: ['Install + provider setup', 'Telegram or Discord gateway', 'Basic memory/profile', '1 starter workflow', 'Handoff notes']
  },
  {
    name: 'Operator Buildout',
    price: 'CAD $1K–$2.5K',
    timeline: '1-week build',
    summary: 'A private AI operator built around your actual recurring work, not a generic chatbot demo.',
    items: ['Workflow audit', '3–5 custom workflows', 'Skills + memory rules', 'Scheduled jobs', '7 days async support'],
    featured: true
  },
  {
    name: 'Operations Retainer',
    price: 'CAD $300–$1.5K',
    timeline: 'Monthly',
    summary: 'For users who start depending on their agent and want monitoring, tuning, new workflows, and reliability support.',
    items: ['Workflow tuning', 'New automations', 'Cost/reliability review', 'Broken integration fixes', 'Monthly review']
  }
];
---

<Layout title={title} description={description}>
  <Nav />

  <main class="site-shell">
    <section class="hero-section" id="top">
      <div class="page-container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Hermes Agent setup platform</p>
          <h1>Private AI operators for real workflows.</h1>
          <p class="hero-lede">
            YongAI sets up Hermes Agent as a practical service layer: a messaging-native assistant with memory, tools, skills, scheduled workflows, and clear approval gates.
          </p>
          <div class="hero-actions">
            <button class="btn btn-primary" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">
              Book a workflow audit
            </button>
            <a class="btn btn-secondary" href="#how-it-works">See how it works</a>
          </div>
          <div class="proof-row" aria-label="Platform highlights">
            <span>Open-source agent framework</span>
            <span>Telegram / Discord / Slack</span>
            <span>Memory + tools + cron</span>
          </div>
        </div>

        <div class="operator-panel" aria-label="Example Hermes operator run">
          <div class="panel-topbar">
            <div>
              <span class="status-dot"></span>
              <strong>Hermes operator</strong>
            </div>
            <span>08:30 run</span>
          </div>
          <div class="message-stack">
            <div class="chat-line agent">Morning brief is ready: 2 meetings, 1 overdue follow-up, 4 new roles, and a draft status update.</div>
            <div class="chat-line user">Prepare the follow-up and update the tracker. Don’t send anything yet.</div>
          </div>
          <div class="run-card">
            <div class="run-card-header">
              <span>Action plan</span>
              <strong>Needs approval</strong>
            </div>
            <ul>
              <li><span>✓</span> Checked calendar, inbox, tracker, and memory</li>
              <li><span>✓</span> Drafted follow-up message</li>
              <li><span>•</span> Waiting for approval before sending</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section white" id="platform">
      <div class="page-container two-column">
        <div>
          <p class="eyebrow">The platform</p>
          <h2>Less demo magic. More operating system.</h2>
          <p class="section-lede">
            The useful version of an AI agent is not a prompt window. It is a small operating layer around your real work: context, tools, procedures, schedules, and boundaries.
          </p>
        </div>
        <div class="pillar-grid">
          {platformPillars.map((pillar) => (
            <article class="pillar-card">
              <p>{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <span>{pillar.body}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="how-it-works">
      <div class="page-container">
        <div class="section-heading narrow">
          <p class="eyebrow">How the setup works</p>
          <h2>Start with boring, useful workflows. Earn autonomy later.</h2>
          <p class="section-lede">The first version should save time without creating risk. Once the agent proves itself, deeper automation becomes much easier to trust.</p>
        </div>
        <div class="steps-grid">
          {setupSteps.map(([number, heading, body]) => (
            <article class="step-card">
              <span>{number}</span>
              <h3>{heading}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section white" id="use-cases">
      <div class="page-container split-heading">
        <div>
          <p class="eyebrow">Workflow examples</p>
          <h2>Built for people with context-heavy work.</h2>
        </div>
        <p class="section-lede">These are starting points, not templates pretending every business is the same. The setup is customized after the workflow audit.</p>
      </div>
      <div class="page-container use-case-grid">
        {useCases.map(([title, body]) => (
          <article class="use-case-card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="safety">
      <div class="page-container safety-band">
        <div>
          <p class="eyebrow">Safety model</p>
          <h2>Useful does not mean reckless.</h2>
          <p>Every build gets explicit operating boundaries so the agent knows when to act, when to draft, and when to stop.</p>
        </div>
        <div class="boundary-list">
          <div><strong>Green</strong><span>Summaries, research, reminders, notes, briefings, draft reports.</span></div>
          <div><strong>Yellow</strong><span>Emails, shared files, public messages, applications, client-facing actions.</span></div>
          <div><strong>Red</strong><span>Payments, legal commitments, destructive deletion, regulated or high-risk decisions.</span></div>
        </div>
      </div>
    </section>

    <section class="section white" id="packages">
      <div class="page-container">
        <div class="section-heading narrow">
          <p class="eyebrow">Packages</p>
          <h2>Clear enough to buy. Custom enough to matter.</h2>
          <p class="section-lede">The pricing reflects the real work: workflow discovery, implementation, documentation, and support — not just running an installer.</p>
        </div>
        <div class="package-grid">
          {packages.map((pkg) => (
            <article class:list={['package-card', pkg.featured && 'featured']}>
              {pkg.featured && <p class="recommended">Recommended</p>}
              <h3>{pkg.name}</h3>
              <div class="price-line"><strong>{pkg.price}</strong><span>{pkg.timeline}</span></div>
              <p>{pkg.summary}</p>
              <ul>
                {pkg.items.map((item) => <li>{item}</li>)}
              </ul>
              <button class="btn btn-secondary package-cta" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">Discuss this package</button>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section final-cta" id="contact">
      <div class="page-container final-grid">
        <div>
          <p class="eyebrow">Start small</p>
          <h2>Bring one workflow that keeps slipping.</h2>
          <p class="section-lede">We will decide whether Hermes is the right tool, what the first safe workflow should be, and what setup path makes sense.</p>
          <div class="hero-actions">
            <button class="btn btn-primary" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">Book the audit</button>
            <a class="btn btn-secondary" href="mailto:gymoltbot@gmail.com?subject=Hermes%20Agent%20Setup%20Inquiry">Email Gary</a>
          </div>
        </div>
        <form class="contact-card" action="https://formspree.io/f/xwvnkpak" method="POST">
          <input type="hidden" name="source" value="YongAI Hermes platform landing page" />
          <label>
            <span>Name</span>
            <input required type="text" name="name" placeholder="Your name" />
          </label>
          <label>
            <span>Email</span>
            <input required type="email" name="email" placeholder="you@example.com" />
          </label>
          <label>
            <span>Workflow</span>
            <textarea name="message" rows="4" placeholder="What would you want the agent to handle first?"></textarea>
          </label>
          <button type="submit" class="btn btn-primary">Send inquiry</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
