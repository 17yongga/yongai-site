---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'Live product',
    category: 'Shared finance',
    url: 'https://useflowt.app/',
    accent: '#000000',
    description: 'Shared budgeting for couples, roommates, trips, and households — built around clear balances, receipt capture, and settlement that people can actually trust.',
    proof: ['Budget Spaces', 'Group settlement', 'Receipt scan', 'AI assistant'],
    signal: 'iOS + Android path'
  },
  {
    name: 'OnlyPets',
    status: 'Production API',
    category: 'Consumer social',
    url: 'https://api.gary-yong.com/pets/health',
    accent: '#000000',
    description: 'A pet-focused social platform with profiles, posts, friends, messaging, a digital store, and a playful in-app economy.',
    proof: ['Social feed', 'Owner + pet DMs', 'Nibbles economy', 'Digital store'],
    signal: 'TestFlight track'
  },
  {
    name: 'NEON 777',
    status: 'Live web platform',
    category: 'Gaming systems',
    url: 'https://gary-yong.com/casino.html',
    accent: '#000000',
    description: 'A browser gaming platform with casino games, poker, achievements, leaderboards, CS2 betting, and account-level history.',
    proof: ['7 games', 'Socket.io poker', 'CS2 betting', 'Bet history'],
    signal: 'Live on web'
  },
  {
    name: 'YourHermes',
    status: 'Service venture',
    category: 'Private AI operators',
    url: 'https://urhermes.com/',
    accent: '#000000',
    description: 'A productized setup service for private AI operators: workflow discovery, Hermes configuration, approval gates, memory, and handoff.',
    proof: ['Workflow audit', 'Hermes setup', 'Approval gates', 'Private operator'],
    signal: 'urhermes.com'
  }
];

const standards = [
  ['01', 'Product proof', 'Each venture needs a working surface people can see, test, or use — not just a concept slide.'],
  ['02', 'Workflow pull', 'Ideas are judged by the workflow pain they remove, the frequency of use, and whether users would return without being pushed.'],
  ['03', 'Operational readiness', 'Builds are reviewed for deployment, support, privacy, data handling, and handoff before they are treated as real products.'],
  ['04', 'Clear next milestone', 'Every track should have one concrete next proof point: users, revenue, distribution, partner validation, or a sharper reason to stop.']
];
---

<Layout
  title="YongAI — Build what proves it"
  description="YongAI builds focused software ventures and AI-enabled workflows with small-team speed, product discipline, and a bias toward working proof."
  ogImage="https://yongai.ca/brand/v3/YongAI_website_header_black_on_light_2400x600.png"
>
  <main class="brand-page">
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="/" class="brand-link" aria-label="YongAI home">
        <img src="/brand/v3/YongAI_horizontal_black_transparent.svg" alt="YongAI" />
      </a>
      <div class="nav-links">
        <a href="#portfolio">Portfolio</a>
        <a href="#method">Method</a>
        <a href="#standards">Standards</a>
        <a href="https://urhermes.com/">YourHermes</a>
      </div>
      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href="#portfolio">Portfolio</a>
          <a href="#method">Method</a>
          <a href="#standards">Standards</a>
          <a href="https://urhermes.com/">YourHermes</a>
        </div>
      </details>
    </nav>

    <section class="hero-section">
      <div class="hero-copy">
        <p class="eyebrow">YongAI / venture portfolio</p>
        <h1><span>Build what</span><span>proves it.</span></h1>
        <p class="hero-sub">
          YongAI builds focused software ventures and AI-enabled workflows with small-team speed, product discipline, and a bias toward moving from idea to working proof fast.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="button primary">View the portfolio</a>
          <a href="https://urhermes.com/" class="button secondary">Explore YourHermes</a>
        </div>
      </div>

      <aside class="portfolio-panel" aria-label="YongAI portfolio summary">
        <div class="panel-card panel-card-main">
          <span class="panel-label">Portfolio signal</span>
          <strong>Four tracks. One operating test.</strong>
          <p>Each venture is evaluated by what exists now, who it serves, and the next proof point needed to justify more time, capital, or distribution.</p>
        </div>
        <div class="panel-card-grid">
          <div><span>01</span><strong>Built</strong><small>working surfaces</small></div>
          <div><span>02</span><strong>Used</strong><small>real workflow pull</small></div>
          <div><span>03</span><strong>Next</strong><small>clear proof milestone</small></div>
        </div>
      </aside>
    </section>

    <section class="proof-strip" aria-label="Portfolio summary">
      <div>
        <strong>4</strong>
        <span>active ventures</span>
      </div>
      <div>
        <strong>2 live</strong>
        <span>products already in market</span>
      </div>
      <div>
        <strong>Toronto</strong>
        <span>operator-led studio</span>
      </div>
      <div>
        <strong>Proof</strong>
        <span>before more capital or scope</span>
      </div>
    </section>

    <section id="portfolio" class="portfolio-section">
      <div class="section-kicker">
        <p class="eyebrow">Current portfolio</p>
        <h2>Four venture tracks.</h2>
      </div>

      <div class="venture-board">
        {ventures.map((venture, index) => (
          <article class={`venture-card card-${index + 1}`} style={`--accent:${venture.accent}`}>
            <div class="card-index">0{index + 1}</div>
            <div class="card-main">
              <div class="card-topline">
                <span>{venture.category}</span>
                <em>{venture.status}</em>
              </div>
              <h3>{venture.name}</h3>
              <p>{venture.description}</p>
            </div>
            <div class="card-footer">
              <div class="proof-tags">
                {venture.proof.map((item) => <span>{item}</span>)}
              </div>
              <a href={venture.url}>Open project →</a>
            </div>
            <div class="signal-dot" aria-hidden="true"></div>
            <small>{venture.signal}</small>
          </article>
        ))}
      </div>
    </section>

    <section id="method" class="method-section">
      <div class="method-visual" aria-hidden="true">
        <div class="method-map">
          <span>Workflow</span>
          <i></i>
          <span>Prototype</span>
          <i></i>
          <span>Proof</span>
          <i></i>
          <span>Playbook</span>
        </div>
      </div>
      <div class="method-copy">
        <p class="eyebrow">Operating method</p>
        <h2>Build the proof. Extract the playbook. Ship the next version.</h2>
        <p>
          YongAI is intentionally not a generic AI shop. The work starts with concrete products and workflow problems, then sharpens into repeatable systems: apps, automations, demos, private operators, and venture experiments.
        </p>
        <div class="method-steps">
          <div><span>Discover</span><strong>Find the workflow that is actually painful.</strong></div>
          <div><span>Prototype</span><strong>Build a usable system, not a slide.</strong></div>
          <div><span>Verify</span><strong>Test locally, deploy carefully, measure the result.</strong></div>
          <div><span>Package</span><strong>Turn repeated wins into a product or service.</strong></div>
        </div>
      </div>
    </section>

    <section id="standards" class="standards-section">
      <div class="section-kicker compact">
        <p class="eyebrow">Evaluation model</p>
        <h2>How a track earns attention.</h2>
      </div>
      <div class="standards-grid">
        {standards.map(([number, title, body]) => (
          <article>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div>
        <p class="eyebrow">Work with YongAI</p>
        <h2>Have a workflow or market worth proving?</h2>
      </div>
      <div class="cta-actions">
        <a href="https://www.linkedin.com/in/gary-yong-66a9ba164" class="button primary">Connect with Gary</a>
        <a href="mailto:gary.yong@yongai.ca" class="button secondary">gary.yong@yongai.ca</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) {
    margin: 0;
    background: #FAF8F2;
  }

  :global(*) { box-sizing: border-box; }

  .brand-page {
    --brand-black: #000000;
    --brand-white: #FFFFFF;
    --brand-charcoal: #0B0C0E;
    --brand-ivory: #FAF8F2;
    --brand-line: rgba(0, 0, 0, .12);
    min-height: 100vh;
    overflow-x: hidden;
    color: #000000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at 72% 10%, rgba(11, 11, 10, 0.045), transparent 34rem),
      linear-gradient(180deg, #FFFFFF 0%, #FAF8F2 42%, #FAF8F2 100%);
  }

  .site-nav,
  .hero-section,
  .proof-strip,
  .portfolio-section,
  .method-section,
  .standards-section,
  .cta-section {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    backdrop-filter: blur(22px);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    width: clamp(168px, 14vw, 188px);
    text-decoration: none;
  }

  .brand-link img {
    display: block;
    width: 100%;
    height: auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    font-size: 13px;
    font-weight: 760;
    letter-spacing: -.01em;
  }

  .nav-links a {
    color: #3B3B3B;
    text-decoration: none;
  }

  .nav-links a:hover { color: #000000; }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    width: 46px;
    height: 46px;
    display: grid;
    place-content: center;
    gap: 5px;
    border: 1px solid rgba(11, 11, 10, .14);
    border-radius: 999px;
    background: rgba(255, 253, 248, .74);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker { display: none; }

  .mobile-menu summary span {
    width: 18px;
    height: 2px;
    display: block;
    border-radius: 999px;
    background: #000000;
  }

  .mobile-menu-panel {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    min-width: 220px;
    padding: 10px;
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 14px;
    background: rgba(255, 253, 248, .96);
    box-shadow: 0 24px 60px rgba(11, 11, 10, .12);
  }

  .mobile-menu-panel a {
    display: block;
    padding: 13px 14px;
    border-radius: 12px;
    color: #000000;
    text-decoration: none;
    font-size: 15px;
    font-weight: 820;
  }

  .mobile-menu-panel a:hover { background: rgba(11, 11, 10, .055); }

  .hero-section {
    min-height: calc(100vh - 84px);
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, .68fr);
    align-items: center;
    gap: clamp(36px, 5vw, 64px);
    padding-block: 56px 86px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: #4A4A4A;
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  h1, h2, h3, p { margin-top: 0; }

  h1, .section-kicker h2, .method-copy h2, .cta-section h2, .panel-card-main strong, .venture-card h3 {
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 24px;
    color: #000000;
    font-size: clamp(58px, 7vw, 96px);
    line-height: .96;
    font-weight: 700;
    letter-spacing: -.025em;
  }

  h1 span { display: block; }

  .hero-copy { min-width: 0; }

  .hero-sub {
    max-width: min(680px, 100%);
    margin-bottom: 34px;
    color: #2F2F2F;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.62;
    overflow-wrap: break-word;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 21px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 850;
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .button:hover { transform: translateY(-2px); }

  .button.primary {
    color: #FFFFFF;
    background: #000000;
    box-shadow: 0 18px 38px rgba(11, 11, 10, .16);
  }

  .button.secondary {
    color: #000000;
    background: rgba(255, 253, 248, .64);
    border: 1px solid rgba(11, 11, 10, .13);
  }

  .portfolio-panel {
    display: grid;
    gap: 16px;
    align-self: center;
  }

  .panel-card,
  .panel-card-grid div {
    border: 1px solid rgba(11, 11, 10, .11);
    background: rgba(255, 253, 248, .72);
    box-shadow: 0 24px 60px rgba(36, 30, 23, .08);
  }

  .panel-card-main {
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: 32px;
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, .9), rgba(245, 241, 232, .78)),
      repeating-linear-gradient(90deg, rgba(11,11,10,.04) 0 1px, transparent 1px 44px),
      repeating-linear-gradient(0deg, rgba(11,11,10,.03) 0 1px, transparent 1px 44px);
  }

  .panel-label {
    width: fit-content;
    margin-bottom: auto;
    padding: 8px 10px;
    border: 1px solid rgba(11, 11, 10, .10);
    border-radius: 999px;
    color: #4A4A4A;
    background: rgba(255,253,248,.68);
    font-size: 11px;
    font-weight: 860;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .panel-card-main strong {
    max-width: 380px;
    margin-bottom: 16px;
    color: #000000;
    font-size: clamp(28px, 2.7vw, 40px);
    line-height: 1.04;
    font-weight: 740;
    letter-spacing: -.018em;
  }

  .panel-card-main p {
    max-width: 390px;
    margin-bottom: 0;
    color: #3B3B3B;
    font-size: 15px;
    line-height: 1.55;
  }

  .panel-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .panel-card-grid div {
    min-height: 128px;
    padding: 18px;
    border-radius: 14px;
  }

  .panel-card-grid span,
  .panel-card-grid strong,
  .panel-card-grid small { display: block; }

  .panel-card-grid span {
    margin-bottom: 22px;
    color: #000000;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .14em;
  }

  .panel-card-grid strong {
    margin-bottom: 4px;
    color: #000000;
    font-size: 18px;
    letter-spacing: -.01em;
  }

  .panel-card-grid small {
    color: #4A4A4A;
    font-size: 12px;
    font-weight: 720;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 14px;
    overflow: hidden;
    background: #000000;
  }

  .proof-strip div {
    min-height: 128px;
    padding: 24px;
    border-right: 1px solid rgba(255, 253, 248, .14);
  }

  .proof-strip div:last-child { border-right: 0; }

  .proof-strip strong,
  .proof-strip span { display: block; }

  .proof-strip strong {
    margin-bottom: 10px;
    color: #FFFFFF;
    font-size: clamp(28px, 4vw, 46px);
    line-height: .95;
    letter-spacing: -.015em;
  }

  .proof-strip span {
    color: rgba(255, 253, 248, .58);
    font-size: 13px;
    font-weight: 700;
  }

  .portfolio-section,
  .standards-section { padding-block: 100px; }

  .section-kicker {
    display: grid;
    grid-template-columns: .66fr 1fr;
    gap: 44px;
    align-items: end;
    margin-bottom: 34px;
  }

  .section-kicker.compact {
    max-width: 780px;
    display: block;
  }

  .section-kicker h2,
  .method-copy h2,
  .cta-section h2 {
    margin: 0;
    color: #000000;
    font-size: clamp(30px, 3.7vw, 48px);
    line-height: 1.08;
    font-weight: 630;
    letter-spacing: -.015em;
  }

  .venture-board {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 18px;
  }

  .venture-card {
    position: relative;
    min-height: 430px;
    grid-column: span 6;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 28px;
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 24px;
    background: rgba(255, 253, 248, .74);
    box-shadow: 0 20px 50px rgba(36, 30, 23, .06);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease, background .22s ease;
  }

  .venture-card:hover {
    transform: translateY(-4px);
    border-color: rgba(11, 11, 10, .22);
    box-shadow: 0 26px 70px rgba(36, 30, 23, .12);
  }

  .venture-card.card-1 { grid-column: span 7; }
  .venture-card.card-2 { grid-column: span 5; }
  .venture-card.card-3 { grid-column: span 5; }
  .venture-card.card-4 { grid-column: span 7; background: #0B0C0E; color: #FFFFFF; }

  .venture-card::before {
    content: '';
    position: absolute;
    inset: auto -40px -70px auto;
    width: 260px;
    height: 260px;
    border: 1px solid rgba(11, 11, 10, .14);
    transform: rotate(24deg);
    opacity: .42;
  }

  .card-index {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    color: #FFFFFF;
    background: #000000;
    font-weight: 850;
    letter-spacing: -.015em;
  }

  .card-4 .card-index { background: #FFFFFF; color: #000000; }

  .card-main { margin-top: 54px; position: relative; z-index: 1; }

  .card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .card-topline span,
  .card-topline em,
  .venture-card small {
    color: #555555;
    font-size: 11px;
    font-style: normal;
    font-weight: 860;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .card-4 .card-topline span,
  .card-4 .card-topline em,
  .card-4 small { color: rgba(255,253,248,.56); }

  .venture-card h3 {
    margin: 0 0 18px;
    color: inherit;
    font-size: clamp(32px, 4vw, 50px);
    line-height: 1.02;
    font-weight: 710;
    letter-spacing: -.018em;
  }

  .venture-card p {
    max-width: 620px;
    margin-bottom: 0;
    color: #2F2F2F;
    font-size: 17px;
    line-height: 1.62;
  }

  .card-4 p { color: rgba(255,253,248,.68); }

  .card-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-top: auto;
    padding-top: 34px;
  }

  .proof-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .proof-tags span {
    padding: 8px 10px;
    border: 1px solid rgba(11, 11, 10, .10);
    border-radius: 999px;
    color: #000000;
    background: rgba(255, 253, 248, .72);
    font-size: 12px;
    font-weight: 760;
  }

  .card-4 .proof-tags span {
    color: rgba(255,253,248,.88);
    border-color: rgba(255,253,248,.14);
    background: rgba(255,253,248,.08);
  }

  .card-footer a {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(11, 11, 10, .13);
    border-radius: 999px;
    color: inherit;
    background: rgba(255, 253, 248, .52);
    font-size: 14px;
    font-weight: 780;
    text-decoration: none;
    transition: transform .22s ease, background .22s ease, border-color .22s ease, box-shadow .22s ease;
  }

  .venture-card:hover .card-footer a,
  .card-footer a:hover {
    transform: scale(1.07);
    border-color: rgba(11, 11, 10, .26);
    background: #000000;
    color: #FFFFFF;
    box-shadow: 0 14px 32px rgba(11, 11, 10, .16);
  }

  .card-4:hover .card-footer a,
  .card-4 .card-footer a:hover {
    border-color: rgba(255, 253, 248, .42);
    background: #FFFFFF;
    color: #000000;
  }

  .signal-dot {
    position: absolute;
    right: 26px;
    top: 26px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #000000;
    box-shadow: 0 0 0 8px rgba(11, 11, 10, .08);
  }

  .venture-card small {
    display: none;
  }

  .method-section {
    display: grid;
    grid-template-columns: .75fr 1fr;
    gap: 18px;
    padding-bottom: 100px;
  }

  .method-visual,
  .method-copy {
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 24px;
    background: rgba(255,253,248,.68);
  }

  .method-visual {
    min-height: 560px;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 36px;
    background:
      repeating-linear-gradient(135deg, rgba(255,253,248,.07) 0 1px, transparent 1px 36px),
      #000000;
  }

  .method-map {
    width: min(100%, 360px);
    display: grid;
    gap: 14px;
  }

  .method-map span {
    display: block;
    padding: 18px 20px;
    border: 1px solid rgba(255,253,248,.16);
    border-radius: 14px;
    color: #FFFFFF;
    background: rgba(255,253,248,.08);
    font-size: 15px;
    font-weight: 850;
