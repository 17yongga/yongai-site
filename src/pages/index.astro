---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'Live / mobile release path',
    category: 'Shared finance app',
    url: 'https://useflowt.app/',
    accent: '#2563EB',
    description: 'Shared budgeting for couples, roommates, trips, and households. Track expenses, split fairly, understand spending, and settle up clearly.',
    details: ['Budget Spaces', 'Group settlement', 'Receipt scan', 'AI assistant'],
    metric: 'iOS + Android'
  },
  {
    name: 'OnlyPets',
    status: 'TestFlight + production API',
    category: 'Pet social platform',
    url: 'https://api.gary-yong.com/pets/health',
    accent: '#BC552A',
    description: 'A pet-focused social app with profiles, posts, friends, messaging, store/economy, and production demo content.',
    details: ['Social feed', 'Owner + pet DMs', 'Nibbles economy', 'Digital store'],
    metric: 'TestFlight'
  },
  {
    name: 'NEON 777 Casino',
    status: 'Live web platform',
    category: 'Gaming / multiplayer',
    url: 'https://gary-yong.com/casino.html',
    accent: '#A855F7',
    description: 'A browser gaming platform with seven live games, credits, achievements, leaderboards, poker, and CS2 betting.',
    details: ['7 games', 'Socket.io poker', 'CS2 betting', 'Bet history'],
    metric: 'Live'
  },
  {
    name: 'YourHermes',
    status: 'New venture',
    category: 'Agent setup service',
    url: 'https://urhermes.com/',
    accent: '#0F766E',
    description: 'A productized setup service for private AI operators: workflow discovery, Hermes configuration, approval gates, memory, and handoff.',
    details: ['Workflow audit', 'Hermes setup', 'Approval gates', 'Private operator'],
    metric: 'urhermes.com'
  }
];
---

<Layout
  title="YongAI — Venture Portfolio"
  description="YongAI is Gary Yong’s venture portfolio for practical products and services: Flowt, OnlyPets, NEON 777 Casino, and YourHermes."
>
  <main class="portfolio-page">
    <nav class="portfolio-nav">
      <a href="/" class="brand" aria-label="YongAI home">
        <span class="brand-mark">Y</span>
        <span>Yong<span>AI</span></span>
      </a>
      <div class="nav-links">
        <a href="#ventures">Ventures</a>
        <a href="#approach">Approach</a>
        <a href="https://urhermes.com/">YourHermes</a>
      </div>
    </nav>

    <section class="hero-section">
      <div class="hero-copy">
        <p class="eyebrow">Gary Yong’s venture portfolio</p>
        <h1>Practical products with real usage behind them.</h1>
        <p class="hero-sub">
          YongAI collects the active products, experiments, and services I’m building — from shared finance and pet social to gaming platforms and private AI operator setup.
        </p>
        <div class="hero-actions">
          <a href="#ventures" class="button primary">View portfolio</a>
          <a href="https://urhermes.com/" class="button secondary">Open YourHermes</a>
        </div>
      </div>

      <aside class="hero-panel" aria-label="Portfolio summary">
        <div class="panel-top">
          <p>Portfolio</p>
          <strong>4 active ventures</strong>
        </div>
        <div class="mini-grid">
          {ventures.map((venture) => (
            <a href={venture.url} class="mini-card" style={`--accent:${venture.accent}`}>
              <span></span>
              <strong>{venture.name}</strong>
              <small>{venture.metric}</small>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section id="ventures" class="ventures-section">
      <div class="section-heading">
        <p class="eyebrow">Current ventures</p>
        <h2>What’s live, shipping, or being validated.</h2>
      </div>

      <div class="venture-grid">
        {ventures.map((venture, index) => (
          <article class={`venture-card venture-${index + 1}`} style={`--accent:${venture.accent}`}>
            <div class="card-header">
              <div>
                <p class="category">{venture.category}</p>
                <h3>{venture.name}</h3>
              </div>
              <span class="status">{venture.status}</span>
            </div>
            <p class="description">{venture.description}</p>
            <div class="detail-list">
              {venture.details.map((detail) => <span>{detail}</span>)}
            </div>
            <a href={venture.url} class="card-link">Open project →</a>
          </article>
        ))}
      </div>
    </section>

    <section id="approach" class="approach-section">
      <div class="approach-card">
        <p class="eyebrow">Operating approach</p>
        <h2>Build the proof first.</h2>
        <p>
          The portfolio is intentionally practical: ship working systems, learn from real usage, tighten the product, and only then turn the pattern into a clearer business or service offer.
        </p>
      </div>
      <div class="principles">
        <div><strong>01</strong><span>Real workflows over pitch-deck ideas.</span></div>
        <div><strong>02</strong><span>Visual, usable products before abstract strategy.</span></div>
        <div><strong>03</strong><span>Trust, safety, and handoff matter for AI services.</span></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) {
    background: #f4f1ea;
  }

  .portfolio-page {
    min-height: 100vh;
    color: #161616;
    background:
      radial-gradient(circle at top right, rgba(194, 65, 12, 0.11), transparent 34rem),
      linear-gradient(180deg, #f8f5ee 0%, #f2eee6 48%, #ebe6dc 100%);
  }

  .portfolio-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 72px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-weight: 900;
    color: #161616;
    text-decoration: none;
    letter-spacing: -0.03em;
  }

  .brand span span { color: #c2410c; }

  .brand-mark {
    width: 34px;
    height: 34px;
    border-radius: 11px;
    display: grid;
    place-items: center;
    color: white;
    background: #161616;
    box-shadow: 0 10px 24px rgba(0,0,0,0.13);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    font-size: 14px;
    font-weight: 700;
  }

  .nav-links a {
    color: #686156;
    text-decoration: none;
  }

  .nav-links a:hover { color: #161616; }

  .hero-section,
  .ventures-section,
  .approach-section {
    max-width: 1180px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  .hero-section {
    min-height: calc(100vh - 72px);
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, 0.72fr);
    align-items: center;
    gap: 48px;
    padding-top: 56px;
    padding-bottom: 84px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: #9a3412;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.19em;
    text-transform: uppercase;
  }

  h1, h2, h3, p { margin-top: 0; }

  h1 {
    max-width: 760px;
    margin-bottom: 26px;
    color: #161616;
    font-size: clamp(54px, 8vw, 104px);
    line-height: 0.91;
    font-weight: 950;
    letter-spacing: -0.075em;
  }

  .hero-sub {
    max-width: 650px;
    margin-bottom: 34px;
    color: #5f584f;
    font-size: 20px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 850;
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .button:hover { transform: translateY(-2px); }

  .button.primary {
    color: white;
    background: #161616;
    box-shadow: 0 18px 34px rgba(0,0,0,.14);
  }

  .button.secondary {
    color: #161616;
    background: rgba(255,255,255,.64);
    border: 1px solid rgba(0,0,0,.1);
  }

  .hero-panel {
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 34px;
    padding: 20px;
    background: rgba(255,255,255,.66);
    box-shadow: 0 30px 70px rgba(35, 27, 18, .11);
  }

  .panel-top {
    padding: 24px;
    border-radius: 24px;
    color: white;
    background: #161616;
  }

  .panel-top p {
    margin-bottom: 8px;
    color: rgba(255,255,255,.52);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .panel-top strong {
    font-size: 36px;
    line-height: 1;
    letter-spacing: -.04em;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
  }

  .mini-card {
    min-height: 126px;
    padding: 18px;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 22px;
    background: white;
    color: #161616;
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease;
  }

  .mini-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 30px rgba(0,0,0,.08);
  }

  .mini-card span {
    display: block;
    width: 40px;
    height: 5px;
    border-radius: 999px;
    margin-bottom: 20px;
    background: var(--accent);
  }

  .mini-card strong,
  .mini-card small { display: block; }

  .mini-card strong {
    margin-bottom: 6px;
    font-size: 17px;
    font-weight: 900;
    letter-spacing: -.04em;
  }

  .mini-card small {
    color: #8a8176;
    font-weight: 750;
  }

  .ventures-section {
    padding-top: 86px;
    padding-bottom: 90px;
  }

  .section-heading {
    display: grid;
    grid-template-columns: .78fr 1fr;
    gap: 42px;
    align-items: end;
    margin-bottom: 32px;
  }

  .section-heading h2,
  .approach-card h2 {
    margin: 0;
    color: #161616;
    font-size: clamp(34px, 5vw, 58px);
    line-height: .98;
    font-weight: 950;
    letter-spacing: -.055em;
  }

  .venture-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .venture-card {
    position: relative;
    min-height: 380px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 30px;
    background: rgba(255,255,255,.74);
    box-shadow: 0 18px 42px rgba(42, 35, 27, .06);
  }

  .venture-card::after {
    content: '';
    position: absolute;
    right: -44px;
    top: -44px;
    width: 180px;
    height: 180px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
  }

  .card-header {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 34px;
  }

  .category,
  .status {
    color: #756d63;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .venture-card h3 {
    margin: 8px 0 0;
    color: #161616;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1;
    font-weight: 950;
    letter-spacing: -.06em;
  }

  .status {
    height: fit-content;
    max-width: 190px;
    padding: 8px 10px;
    border-radius: 999px;
    text-align: right;
    background: rgba(255,255,255,.68);
    border: 1px solid rgba(0,0,0,.08);
  }

  .description {
    position: relative;
    z-index: 1;
    max-width: 580px;
    color: #4f4942;
    font-size: 18px;
    line-height: 1.65;
  }

  .detail-list {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 28px;
  }

  .detail-list span {
    padding: 8px 11px;
    border-radius: 999px;
    color: #332f2b;
    background: rgba(255,255,255,.70);
    border: 1px solid rgba(0,0,0,.08);
    font-size: 12px;
    font-weight: 800;
  }

  .card-link {
    position: relative;
    z-index: 1;
    width: fit-content;
    margin-top: 24px;
    color: #161616;
    font-weight: 900;
    text-decoration: none;
  }

  .card-link:hover { color: var(--accent); }

  .approach-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    padding-bottom: 96px;
  }

  .approach-card,
  .principles {
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 30px;
    background: #161616;
    color: white;
  }

  .approach-card { padding: 34px; }

  .approach-card .eyebrow { color: rgba(255,255,255,.44); }

  .approach-card h2 { color: white; }

  .approach-card p {
    max-width: 640px;
    margin-top: 22px;
    color: rgba(255,255,255,.66);
    font-size: 18px;
    line-height: 1.7;
  }

  .principles {
    display: grid;
    background: rgba(255,255,255,.72);
    color: #161616;
    overflow: hidden;
  }

  .principles div {
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 18px;
    align-items: center;
    padding: 24px 28px;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  .principles div:last-child { border-bottom: 0; }

  .principles strong {
    color: #c2410c;
    font-size: 13px;
    letter-spacing: .16em;
  }

  .principles span {
    color: #2e2924;
    font-size: 18px;
    font-weight: 850;
    line-height: 1.35;
    letter-spacing: -.02em;
  }

  @media (max-width: 880px) {
    .nav-links { display: none; }
    .hero-section,
    .section-heading,
    .approach-section {
      grid-template-columns: 1fr;
    }
    .hero-section {
      min-height: 0;
      padding-top: 42px;
    }
    .venture-grid { grid-template-columns: 1fr; }
    h1 { font-size: clamp(50px, 15vw, 78px); }
  }

  @media (max-width: 520px) {
    .portfolio-nav,
    .hero-section,
    .ventures-section,
    .approach-section {
      padding-left: 18px;
      padding-right: 18px;
    }
    .mini-grid { grid-template-columns: 1fr; }
    .card-header {
      flex-direction: column;
    }
    .status { text-align: left; }
  }
</style>
