---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'YongAI — Private AI Operator Setup';
const description = 'YongAI sets up private AI operators for founders and operators: workflow discovery, Hermes setup, safety rules, and verified handoff.';

const buyerQuestions = [
  {
    label: 'What is it?',
    title: 'A private AI operator',
    body: 'An agent configured for your work, tools, context, and approval rules.'
  },
  {
    label: 'What does it do?',
    title: 'Closes repeatable loops',
    body: 'Turns messy input into briefs, plans, QA evidence, trackers, drafts, and follow-ups.'
  },
  {
    label: 'Why not just ChatGPT?',
    title: 'It remembers the workflow',
    body: 'Custom skills, memory, schedules, files, browser checks, and handoff rules make it reusable.'
  },
  {
    label: 'What do I buy?',
    title: 'A working setup sprint',
    body: 'One valuable workflow mapped, built, tested, documented, and handed over.'
  }
];

const benTrail = [
  ['01', 'Initial ask', '“I want an agent that can keep working from chat.”'],
  ['02', 'Real use case', 'Feature or bug → repo/app inspection → browser QA → review-ready handoff.'],
  ['03', 'What got prepared', 'Workspace files, memory rules, custom skills, dev protocol, QA checklist, command dashboard.'],
  ['04', 'Safety line', 'Agent prepares the work. Human approves external actions, PRs, deploys, and production changes.']
];

const setupSteps = [
  ['01', 'Pick the loop', 'Find the one workflow worth automating first.'],
  ['02', 'Build the operator', 'Configure Hermes, tools, memory, skills, prompts, and permissions.'],
  ['03', 'Prove it works', 'Run real examples, fix gaps, and hand over the operating guide.']
];

const workflowExamples = [
  ['Product command center', 'Ideas, bugs, notes → plans, tests, status updates.'],
  ['Customer feedback', 'Calls/support/demo notes → themes, priorities, next actions.'],
  ['Development QA', 'Issue → reproduce → fix path → browser/test evidence.'],
  ['Weekly ops brief', 'Changes, blockers, decisions, and next steps.'],
  ['AI radar', 'Relevant updates → practical experiments, not newsletter noise.'],
  ['Career / life admin', 'Trackers, follow-ups, reminders, prep, journaling.']
];

const packages = [
  {
    name: 'Workflow Audit',
    price: 'CAD $299–$499',
    timeline: 'Single session',
    summary: 'Know what to build first.',
    items: ['Workflow map', 'Use-case ranking', 'Risk/access notes', 'Recommended setup plan']
  },
  {
    name: 'AI Workflow Setup Sprint',
    price: 'CAD $1K–$2.5K',
    timeline: 'Few days to 1 week',
    summary: 'Your first working AI operator.',
    items: ['Hermes setup', '1–3 workflows', 'Custom skills + memory', 'Tested handoff guide', 'Short support window'],
    featured: true
  },
  {
    name: 'Ops Retainer',
    price: 'CAD $300–$1.5K',
    timeline: 'Monthly',
    summary: 'Keep improving the operator.',
    items: ['New workflows', 'Tuning/fixes', 'Scheduled checks', 'Integration support']
  }
];
---

<Layout title={title} description={description}>
  <Nav />

  <main class="site-shell">
    <section class="hero-section" id="top">
      <div class="page-container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">AI Workflow Setup Sprint</p>
          <h1>Your private AI operator.</h1>
          <p class="hero-lede">
            YongAI turns one messy, repeatable workflow into a Hermes agent setup that can help every week — with your context, your tools, and clear approval boundaries.
          </p>
          <div class="hero-actions">
            <button class="btn btn-primary" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">
              Book a workflow audit
            </button>
            <a class="btn btn-secondary" href="#example">See a real setup pattern</a>
          </div>
          <div class="proof-row" aria-label="Service highlights">
            <span>Workflow map</span>
            <span>Hermes setup</span>
            <span>Custom skills</span>
            <span>Verified handoff</span>
          </div>
        </div>

        <div class="operator-panel" aria-label="Example Hermes operator run">
          <div class="panel-topbar">
            <div>
              <span class="status-dot"></span>
              <strong>Private AI operator</strong>
            </div>
            <span>Human-gated</span>
          </div>
          <div class="message-stack">
            <div class="chat-line user">Customer says onboarding breaks after email verification.</div>
            <div class="chat-line agent">I’ll turn that into requirements, risks, test cases, and a review-ready handoff.</div>
          </div>
          <div class="run-card">
            <div class="run-card-header">
              <span>Output</span>
              <strong>Ready to review</strong>
            </div>
            <ul>
              <li><span>✓</span> Problem summarized</li>
              <li><span>✓</span> Context checked</li>
              <li><span>✓</span> Actions + tests drafted</li>
              <li><span>•</span> Waits before sending or deploying</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section white" id="platform">
      <div class="page-container two-column">
        <div>
          <p class="eyebrow">Two-minute version</p>
          <h2>A working workflow. Not an AI toy.</h2>
        </div>
        <div class="pillar-grid">
          {buyerQuestions.map((pillar) => (
            <article class="pillar-card">
              <p>{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <span>{pillar.body}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="example">
      <div class="page-container">
        <div class="section-heading narrow">
          <p class="eyebrow">Example setup pattern</p>
          <h2>Ben’s setup pattern.</h2>
        </div>
        <div class="use-case-grid">
          {benTrail.map(([number, heading, body]) => (
            <article class="step-card">
              <span>{number}</span>
              <h3>{heading}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section white" id="how-it-works">
      <div class="page-container">
        <div class="section-heading narrow">
          <p class="eyebrow">How it works</p>
          <h2>One useful loop first.</h2>
        </div>
        <div class="steps-grid">
          {setupSteps.map(([number, heading, body]) => (
            <article class="step-card">
              <span>{number}</span>
              <h3>{heading}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="use-cases">
      <div class="page-container split-heading">
        <div>
          <p class="eyebrow">Good first workflows</p>
          <h2>Context-heavy work you repeat.</h2>
        </div>
      </div>
      <div class="page-container use-case-grid">
        {workflowExamples.map(([title, body]) => (
          <article class="use-case-card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section white" id="safety">
      <div class="page-container safety-band">
        <div>
          <p class="eyebrow">Safety model</p>
          <h2>Autonomy with boundaries.</h2>
        </div>
        <div class="boundary-list">
          <div><strong>Green</strong><span>Summaries, research, trackers, drafts, QA notes, briefs.</span></div>
          <div><strong>Yellow</strong><span>Emails, public posts, files, PRs, applications, deployments.</span></div>
          <div><strong>Red</strong><span>Payments, legal commitments, secrets, destructive deletion.</span></div>
        </div>
      </div>
    </section>

    <section class="section white" id="packages">
      <div class="page-container">
        <div class="section-heading narrow">
          <p class="eyebrow">Packages</p>
          <h2>Start small. Leave with it working.</h2>
        </div>
        <div class="package-grid">
          {packages.map((pkg) => (
            <article class:list={['package-card', pkg.featured && 'featured']}>
              {pkg.featured && <p class="recommended">Recommended</p>}
              <h3>{pkg.name}</h3>
              <div class="price-line"><strong>{pkg.price}</strong><span>{pkg.timeline}</span></div>
              <p>{pkg.summary}</p>
              <ul>
                {pkg.items.map((item) => <li>{item}</li>)}
              </ul>
              <button class="btn btn-secondary package-cta" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">Discuss this package</button>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section final-cta" id="contact">
      <div class="page-container final-grid">
        <div>
          <p class="eyebrow">Next step</p>
          <h2>What should your AI operator handle?</h2>
          <div class="hero-actions">
            <button class="btn btn-primary" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/gary-yong-yongai/30min'});return false;">Book the audit</button>
            <a class="btn btn-secondary" href="mailto:gymoltbot@gmail.com?subject=AI%20Workflow%20Setup%20Inquiry">Email Gary</a>
          </div>
        </div>
        <form class="contact-card" action="https://formspree.io/f/xwvnkpak" method="POST">
          <input type="hidden" name="source" value="YongAI AI workflow setup landing page" />
          <label>
            <span>Name</span>
            <input required type="text" name="name" placeholder="Your name" />
          </label>
          <label>
            <span>Email</span>
            <input required type="email" name="email" placeholder="you@example.com" />
          </label>
          <label>
            <span>Workflow</span>
            <textarea name="message" rows="4" placeholder="What should your AI operator handle first?"></textarea>
          </label>
          <button type="submit" class="btn btn-primary">Send inquiry</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
