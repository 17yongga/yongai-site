---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const projects = [
  {
    code: '01',
    name: 'NEON 777 Casino Platform',
    stage: 'Product Demo',
    category: 'Virtual-credit gaming',
    tagline: 'A neon casino floor in the browser.',
    thesis:
      'A browser-based virtual-credit casino and CS2 fantasy betting platform with a persistent account layer, shared bankroll, seven game modes, and social retention systems.',
    customer: 'Gamers, CS2/esports fans, demo viewers, and community users who enjoy competitive virtual-credit play.',
    model: 'Portfolio demo, community entertainment, operator-facing product exploration, and future compliance-first tooling.',
    focus: 'Seven games, one shared credit balance, leaderboards, achievements, stats, bet history, and responsive desktop/mobile play.',
    audience: 'Gaming operators, product partners, compliance advisors, and technical collaborators.',
    evidence: 'Rendered desktop and mobile product, shared virtual-credit bankroll, account state, game catalog, CS2 board, and retention surfaces.',
    nextMilestone: 'Decide whether the strongest path is community entertainment, licensed operator tooling, or compliance-first B2B infrastructure.',
    proofLabel: 'Built surfaces',
    proof: ['Seven-game lobby', 'Shared virtual-credit balance', 'CS2 fantasy betting board', 'Desktop and mobile UI'],
    compliance: 'Virtual credits only. No real money is involved.',
    liveHref: 'https://gary-yong.com/casino.html',
    images: {
      hero: '/portfolio/casino/lobby-hero.png',
      mobile: '/portfolio/casino/mobile-lobby.png',
      gallery: [
        ['/portfolio/casino/game-grid.png', 'Seven-game lobby and social sidebar'],
        ['/portfolio/casino/cs2-board.png', 'CS2 fantasy betting board'],
      ],
    },
    className: 'casino',
  },
  {
    code: '02',
    name: 'Flowt',
    stage: 'Live App',
    category: 'Personal finance',
    tagline: 'Budget together, stress less.',
    thesis:
      'A shared expense tracking app for couples and roommates: add expenses, scan receipts with AI, split costs fairly, and settle who owes what without spreadsheets or awkward money talks.',
    customer: 'Couples, roommates, and shared households splitting rent, groceries, dinners, utilities, trips, and everyday purchases.',
    model: 'Freemium consumer app with Flowt Pro subscriptions for unlimited tracking, AI receipt scanning, full chart history, and priority support.',
    focus: 'Household onboarding, shared expense entry, receipt scanning, category budgets, partner settlement, secure login, and subscription conversion.',
    audience: 'Consumer-finance partners, App Store growth collaborators, household budgeting communities, and privacy/compliance advisors.',
    evidence: 'Expo app with rendered iPhone screens for dashboard, transaction history, category charts, receipt scanning, settlement flow, settings, paywall, and App Store screenshot set. App Store copy and review notes are drafted.',
    nextMilestone: 'Instrument retention, household invites, scan-to-save completion, subscription conversion, privacy policy readiness, and App Store review operations.',
    proofLabel: 'Built surfaces',
    proof: ['Shared household dashboard', 'AI receipt scanner', 'Category charts', 'Settlement flow', 'Flowt Pro paywall'],
    compliance: 'Personal-finance data product. Privacy, secure storage, and App Store review readiness are central risks to de-risk.',
    images: {
      hero: '/portfolio/flowt/dashboard.png',
      mobile: '/portfolio/flowt/receipt-scan.png',
      gallery: [
        ['/portfolio/flowt/dashboard.png', 'Shared household dashboard and monthly budget state'],
        ['/portfolio/flowt/charts.png', 'Shared spending trends and budget pace'],
        ['/portfolio/flowt/settlements.png', 'One-tap settlement and who-owes-what clarity'],
        ['/portfolio/flowt/flowt-pro-upgrade.png', 'Flowt Pro pricing and premium receipt scanning'],
      ],
    },
    className: 'flowt',
  },
  {
    code: '03',
    name: 'Only Pets',
    stage: 'Prototype',
    category: 'Pet community',
    tagline: 'Pet life, shared by pet people.',
    thesis:
      'A mobile pet community where owners share photos, care notes, recommendations, and daily updates while earning and spending an in-app currency called Nibbles.',
    customer: 'Pet owners, multi-pet households, pet creators, and people looking for peer-sourced food, training, vet, wellness, gear, and care recommendations.',
    model: 'Nibbles top-ups, in-app store purchases, pet subscriptions, creator premium posts, and partner-friendly categories across food, toys, insurance, accessories, badges, and rewards.',
    focus: 'Topic-based discovery feed, pet-first profiles, post creation, owner messaging, social graph, Nibbles rewards, store surfaces, notifications, and subscription paths.',
    audience: 'Pet owners, pet creators, local pet communities, food brands, clinics, insurers, trainers, groomers, and pet-care partners.',
    evidence: 'Captured actual Expo app screens for discovery feed, post detail, composer, store, messages, profile, Nibbles top-up, pet subscriptions, and notifications using seeded marketing data.',
    nextMilestone: 'Validate whether the strongest wedge is practical care discovery, creator subscriptions, Nibbles-based retention, or partner commerce with a focused beta community.',
    proofLabel: 'Built surfaces',
    proof: ['Discovery feed', 'Pet profiles', 'Post composer', 'Messages', 'Nibbles store', 'Creator subscriptions', 'Notifications'],
    compliance: 'Pet-care community product. Medical, insurance, marketplace, and virtual-currency claims should stay practical and reviewed before paid media or partner launches.',
    images: {
      hero: '/portfolio/onlypets/home-discovery-feed.png',
      mobile: '/portfolio/onlypets/pet-profile-subscriptions.png',
      gallery: [
        ['/portfolio/onlypets/post-detail.png', 'Pet-care notes and community recommendations'],
        ['/portfolio/onlypets/create-post-composer.png', 'Photo, caption, sticker, and premium-post creation'],
        ['/portfolio/onlypets/store-home.png', 'Nibbles store and reward marketplace'],
        ['/portfolio/onlypets/messages-inbox.png', 'Owner-to-owner messaging and recommendation follow-up'],
        ['/portfolio/onlypets/nibbles-top-up.png', 'Nibbles top-up and monetization surface'],
        ['/portfolio/onlypets/profile-wallet-menu.png', 'Profile, wallet, rewards, and account surface'],
      ],
    },
    className: 'pets',
  },
  {
    code: '04',
    name: 'Ghostwriter',
    stage: 'Concept',
    category: 'Writing workflow',
    tagline: 'A guided system for turning life stories into manuscripts.',
    thesis:
      'A guided writing product for memoirs, founder stories, family history, and expert nonfiction.',
    customer: 'Founders, families, creators, coaches, and experts.',
    model: 'Project packages, monthly writing workflows, assisted editing, partner licensing.',
    focus: 'Turning interviews and ideas into outlines, chapter plans, and polished drafts.',
    audience: 'Pilot customers, editors, writing coaches, and creator partners.',
    evidence: 'Concept direction. Next materials should show intake, interview capture, outline generation, chapter planning, and editorial QA.',
    nextMilestone: 'Pilot the assisted writing workflow with a narrow customer niche and a packaged manuscript outcome.',
    proofLabel: 'Materials needed',
    proof: ['Interview intake flow', 'Outline builder', 'Chapter workspace', 'Sample manuscript package'],
    placeholder: 'Interview capture, outline system, chapter plan, editing workflow, export package.',
    className: 'ghostwriter',
  },
];

const maturityTracks = [
  ['Live App', 'Flowt', 'Distribution and retention proof next'],
  ['Product Demo', 'NEON 777', 'Built product depth and compliance path next'],
  ['Prototype', 'Only Pets', 'Beta user and creator proof next'],
  ['Concept', 'Ghostwriter', 'Pilot workflow and package proof next'],
];

const proofFramework = [
  ['Market Pull', 'Who has the pain, why now, and how urgently do they act?'],
  ['Product Wedge', 'What narrow product surface proves the venture can exist?'],
  ['Distribution Path', 'Which community, partner, channel, or operator can unlock adoption?'],
  ['Economic Logic', 'Where can repeat usage, pricing, licensing, or ownership compound?'],
];

const studioPrinciples = [
  ['Thesis before build', 'Every venture starts with a specific market belief, not a generic idea. We name the buyer, the pain, the wedge, and the risk before adding scope.'],
  ['Evidence before capital', 'We prefer product demos, pilots, waitlists, pricing tests, usage data, and partner conversations over polished hypotheticals.'],
  ['Risk is part of design', 'Regulatory, privacy, moderation, copyright, and platform risks are treated as product constraints early, not cleanup later.'],
  ['Portfolio discipline', 'Each track has a current proof state and a next milestone, so the studio can decide what deserves more time, capital, or partnership.'],
  ['Ownership mindset', 'The aim is to form durable ventures that can earn trust and revenue, not one-off experiments that disappear after launch.'],
];

const modelSteps = [
  ['01', 'Find', 'Start with a market pressure, underserved workflow, community behavior, or regulated edge that creates a reason to build now.', 'Output: venture thesis'],
  ['02', 'Shape', 'Define the customer, wedge, brand, prototype, business model, and risk boundary before the roadmap expands.', 'Output: testable product brief'],
  ['03', 'Prove', 'Use demos, pilots, interviews, pricing, usage signals, and partner interest to separate curiosity from demand.', 'Output: evidence package'],
  ['04', 'Compound', 'Move the strongest tracks toward repeat use, distribution, revenue, and strategic partnership while holding or retiring weaker ones.', 'Output: investable venture path'],
];

const collaborationSlots = [
  ['Founders', 'Bring a domain thesis, unfair insight, or audience wedge. The studio helps shape it into product, proof, and a commercial path.'],
  ['Operators and advisors', 'Bring market access, compliance judgment, workflow pain, or customer context that can de-risk a venture early.'],
  ['Capital and strategic partners', 'Engage once a track has enough proof to support pilots, distribution, operating support, or investment discussion.'],
];
---

<Layout
  title="YONG Venture Studio | Toronto Venture Studio"
  description="YONG Venture Studio builds and validates practical software ventures with founders, operators, advisors, and early customers."
>
  <Nav />

  <main id="top" class="studio-redesign">
    <section class="editorial-hero" aria-labelledby="hero-title">
      <div class="studio-shell editorial-hero-grid">
        <div class="hero-index" aria-label="Studio index">
          <p>YVS / 2026</p>
          <a href="#ventures">Portfolio</a>
          <a href="#studio-system">How we work</a>
          <a href="#operating-model">Studio model</a>
          <a href="#contact">Contact</a>
        </div>

        <div class="hero-statement">
          <p class="studio-kicker">Commercial venture studio / Toronto</p>
          <h1 id="hero-title" class="hero-title-lockup">
            <span class="hero-title-brand">YONG</span>
            <span class="hero-title-main">Venture Studio</span>
          </h1>
          <p>
            We build and validate practical software ventures before they become capital-intensive companies.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a href="#ventures" class="btn-primary">Explore portfolio</a>
            <a href="#contact" class="btn-secondary">Work with the studio</a>
          </div>
        </div>

        <div class="hero-board proof-board" aria-label="Portfolio maturity board">
          <div class="board-top">
            <span>Portfolio Maturity Board</span>
            <span>Where each track stands now</span>
          </div>
          <div class="maturity-board">
            {maturityTracks.map(([stage, name, next], index) => (
              <article>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <p>{stage}</p>
                  <h2>{name}</h2>
                  <small>{next}</small>
                </div>
              </article>
            ))}
          </div>
          <div class="board-bottom">
            <span>Concept -> Prototype -> Live -> Scale</span>
            <span>Proof before capital</span>
          </div>
        </div>
      </div>
    </section>

    <section class="proof-band" aria-labelledby="proof-title">
      <div class="studio-shell proof-band-grid">
        <div>
          <p class="studio-kicker">/ Investment lens</p>
          <h2 id="proof-title">What we prove before a venture deserves more capital.</h2>
        </div>
        <div class="proof-framework">
          {proofFramework.map(([title, copy], index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="studio-section studio-thesis" aria-labelledby="thesis-title">
      <div class="studio-shell thesis-grid">
        <div>
          <p class="studio-kicker">/ Studio thesis</p>
          <h2 id="thesis-title">A focused studio for turning early signal into investable proof.</h2>
        </div>
        <div class="thesis-copy">
          <p>
            YONG Venture Studio is built around a simple belief: small, well-scoped software ventures can reveal serious commercial opportunities before they require heavy capital.
          </p>
          <p>
            The portfolio spans consumer finance, virtual-credit gaming, pet media, and assisted writing. Each track is evaluated by product proof, market pull, distribution path, and the risks that must be de-risked before scale.
          </p>
        </div>
      </div>
    </section>

    <section id="ventures" class="studio-section venture-index" aria-labelledby="ventures-title">
      <div class="studio-shell">
        <div class="section-row">
          <p class="studio-kicker">/ Portfolio</p>
          <h2 id="ventures-title">Current venture tracks.</h2>
        </div>

        <div class="portfolio-stack">
          {projects.map((project) => (
            <article class={`project-case ${project.className} ${project.images ? 'has-assets' : 'needs-assets'}`}>
              <div class="project-case-head">
                <div class="project-meta">
                  <span>{project.code}</span>
                  <span>{project.stage}</span>
                  <span>{project.category}</span>
                </div>
                <h3>{project.name}</h3>
                <p class="project-tagline">{project.tagline}</p>
                <p>{project.thesis}</p>
                <div class="project-actions">
                  {project.liveHref && (
                    <a href={project.liveHref} target="_blank" rel="noopener" class="project-link">View live demo</a>
                  )}
                  <a href="#contact" class="project-link secondary">Discuss this track</a>
                </div>
              </div>

              <div class="project-media">
                {project.images ? (
                  <>
                    {(project.className === 'flowt' || project.className === 'pets') && (
                      <div class="app-poster-copy">
                        <span>{project.stage}</span>
                        <strong>
                          {project.className === 'flowt'
                            ? 'Split smarter. Settle faster.'
                            : 'Built for daily pet discovery.'}
                        </strong>
                        <em>
                          {project.className === 'flowt'
                            ? 'Shared expenses, receipt scanning, and settlement flow in one app.'
                            : 'Care posts, profiles, rewards, and community commerce surfaces.'}
                        </em>
                      </div>
                    )}
                    <figure class={`project-hero-shot ${project.className === 'flowt' || project.className === 'pets' ? 'app-device-frame' : ''}`}>
                      {project.className === 'flowt' || project.className === 'pets' ? (
                        <span class="device-screen">
                          <span class="device-viewport">
                            <span class="device-status" aria-hidden="true">
                              <span class="device-time">9:41</span>
                              <span class="device-icons">
                                <i class="signal"></i>
                                <i class="wifi"></i>
                                <i class="battery"></i>
                              </span>
                            </span>
                            <span class="device-island" aria-hidden="true">
                              <i></i>
                            </span>
                            <span class="device-content">
                              <img src={project.images.hero} alt={`${project.name} product interface`} loading="lazy" />
                            </span>
                          </span>
                        </span>
                      ) : (
                        <img src={project.images.hero} alt={`${project.name} product interface`} loading="lazy" />
                      )}
                    </figure>
                    {!(project.className === 'flowt' || project.className === 'pets') && (
                      <figure class="project-phone-shot">
                        <img src={project.images.mobile} alt={`${project.name} mobile interface`} loading="lazy" />
                      </figure>
                    )}
                  </>
                ) : (
                  <div class="project-placeholder" aria-label={`${project.name} media placeholder`}>
                    <span>{project.name}</span>
                    <p>{project.placeholder}</p>
                    <div class="placeholder-lines" aria-hidden="true">
                      <i></i><i></i><i></i>
                    </div>
                  </div>
                )}
              </div>

              <details class="project-deep-dive">
                <summary>
                  <span>Explore project details</span>
                  <small>Audience, evidence, model, next milestone, and product screens</small>
                </summary>

                <div class="project-deep-content">
                  <dl class="project-intel">
                    <div>
                      <dt>Audience</dt>
                      <dd>{project.audience}</dd>
                    </div>
                    <div>
                      <dt>Evidence</dt>
                      <dd>{project.evidence}</dd>
                    </div>
                    <div>
                      <dt>Model</dt>
                      <dd>{project.model}</dd>
                    </div>
                    <div>
                      <dt>Next milestone</dt>
                      <dd>{project.nextMilestone}</dd>
                    </div>
                  </dl>

                  <div class="project-proof">
                    <div>
                      <span>{project.proofLabel}</span>
                      {project.compliance && <strong>{project.compliance}</strong>}
                    </div>
                    <ul>
                      {project.proof.map((item) => <li>{item}</li>)}
                    </ul>
                  </div>

                  {project.images && (
                    <div class="project-gallery" aria-label={`${project.name} screenshot gallery`}>
                      {project.images.gallery.map(([src, caption]) => (
                        <figure class={project.className === 'flowt' || project.className === 'pets' ? 'app-gallery-frame' : ''}>
                          {project.className === 'flowt' || project.className === 'pets' ? (
                            <span class="device-screen">
                              <span class="device-viewport">
                                <span class="device-status" aria-hidden="true">
                                  <span class="device-time">9:41</span>
                                  <span class="device-icons">
                                    <i class="signal"></i>
                                    <i class="wifi"></i>
                                    <i class="battery"></i>
                                  </span>
                                </span>
                                <span class="device-island" aria-hidden="true">
                                  <i></i>
                                </span>
                                <span class="device-content">
                                  <img src={src} alt={`${project.name}: ${caption}`} loading="lazy" />
                                </span>
                              </span>
                            </span>
                          ) : (
                            <img src={src} alt={`${project.name}: ${caption}`} loading="lazy" />
                          )}
                          <figcaption>{caption}</figcaption>
                        </figure>
                      ))}
                    </div>
                  )}
                </div>
              </details>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="studio-system" class="studio-section studio-system" aria-labelledby="system-title">
      <div class="studio-shell system-grid">
        <div class="system-copy">
          <p class="studio-kicker">/ How we work</p>
          <h2 id="system-title">A discipline for making early ventures legible.</h2>
          <p>
            The point is not to make every idea look exciting. It is to make each venture understandable enough for partners, operators, and capital to judge what is real, what is still unknown, and what must happen next.
          </p>
        </div>

        <div class="system-board" aria-label="Studio principles">
          {studioPrinciples.map(([name, desc], index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{name}</h3>
              <p>{desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="operating-model" class="studio-section operating-model" aria-labelledby="model-title">
      <div class="studio-shell">
        <div class="section-row model-row">
          <p class="studio-kicker">/ Studio model</p>
          <h2 id="model-title">From market signal to a venture worth backing.</h2>
        </div>

        <div class="decision-grid">
          {modelSteps.map(([code, title, copy, output]) => (
            <article>
              <span>{code}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
              <small>{output}</small>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="studio-section template-slots" aria-labelledby="slots-title">
      <div class="studio-shell slots-grid">
        <div>
          <p class="studio-kicker">/ Collaboration</p>
          <h2 id="slots-title">The right partner depends on the proof stage.</h2>
          <p class="collaboration-intro">
            YONG Venture Studio is most useful when collaborators bring something that reduces uncertainty: distribution, domain knowledge, technical leverage, regulatory judgment, customer access, or capital discipline.
          </p>
        </div>

        <div class="slot-stack">
          {collaborationSlots.map(([title, copy]) => (
            <article>
              <span>{title}</span>
              <p>{copy}</p>
              <div class="slot-line"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="studio-section contact-section">
      <div class="studio-shell">
        <ContactForm />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
