---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'Live product',
    tag: 'Shared finance',
    url: 'https://useflowt.app/',
    accent: '#2563EB',
    description: 'A shared-money app for couples, roommates, trips, and households — capture expenses, split fairly, understand budgets, and settle without spreadsheet chaos.',
    proof: ['iOS + Android release path', 'Live production backend', 'Assistant, settlements, receipts, Budget Spaces']
  },
  {
    name: 'OnlyPets',
    status: 'TestFlight / production API',
    tag: 'Pet social app',
    url: 'https://api.gary-yong.com/pets/health',
    accent: '#F97316',
    description: 'A mobile social platform for pet owners: profiles, posts, store/economy, friends, pet-to-pet and owner messaging, and real demo content backed by production APIs.',
    proof: ['TestFlight build path', 'Production API live', 'Social feed, chat, store, Nibbles economy']
  },
  {
    name: 'NEON 777 Casino',
    status: 'Live platform',
    tag: 'Multiplayer games',
    url: 'https://gary-yong.com/casino.html',
    accent: '#A855F7',
    description: 'A browser casino and gaming platform with seven live games, credits, achievements, history, leaderboards, real-time poker, and CS2 match betting.',
    proof: ['7 games live', 'Socket.io multiplayer', 'CS2 betting via bo3.gg']
  },
  {
    name: 'YourHermes',
    status: 'New venture',
    tag: 'Private AI operator setup',
    url: 'https://urhermes.com/',
    accent: '#0F766E',
    description: 'A productized service for setting up private AI operators: workflow discovery, Hermes configuration, approval gates, memory, scheduled checks, and handoff documentation.',
    proof: ['Dedicated urhermes.com domain', 'Workflow before tools', 'Trust before autonomy']
  }
];

const principles = [
  'Build useful products in public, then turn the working patterns into services.',
  'Favor calm, practical tools over generic AI hype.',
  'Keep every venture grounded in real workflows, real users, and shipped artifacts.'
];
---

<Layout
  title="YongAI — Ventures by Gary Yong"
  description="YongAI is Gary Yong’s venture studio for practical AI, product, and workflow businesses — including Flowt, OnlyPets, NEON 777 Casino, and YourHermes."
>
  <main class="min-h-screen bg-[#F7F4EE] text-[#171717]">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-black/5 bg-[#F7F4EE]/88 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
        <a href="/" class="flex items-center gap-2.5 font-black tracking-tight text-lg">
          <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-[#171717] text-sm text-white">Y</span>
          <span>Yong<span class="text-[#C2410C]">AI</span></span>
        </a>
        <div class="hidden items-center gap-8 text-sm font-semibold text-[#5F5A52] md:flex">
          <a href="#ventures" class="hover:text-[#171717]">Ventures</a>
          <a href="#thesis" class="hover:text-[#171717]">Thesis</a>
          <a href="https://urhermes.com/" class="hover:text-[#171717]">YourHermes</a>
        </div>
      </div>
    </nav>

    <section class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-28">
      <div class="absolute left-1/2 top-16 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-[#F97316]/10 blur-3xl"></div>
      <div class="relative mx-auto max-w-7xl px-6">
        <div class="grid gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
          <div>
            <p class="mb-5 inline-flex rounded-full border border-black/10 bg-white/70 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-[#7C2D12] shadow-sm">
              Venture studio · Toronto
            </p>
            <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-[-0.055em] text-[#171717] md:text-7xl lg:text-8xl">
              Building practical products, not pitch decks.
            </h1>
            <p class="mt-7 max-w-2xl text-lg leading-8 text-[#5F5A52] md:text-xl">
              YongAI is the home for Gary Yong’s active ventures — consumer apps, workflow tools, gaming experiments, and agent setup services that are tested through real usage instead of theory.
            </p>
            <div class="mt-10 flex flex-wrap gap-3">
              <a href="#ventures" class="rounded-full bg-[#171717] px-6 py-3 text-sm font-bold text-white shadow-lg shadow-black/10 transition hover:-translate-y-0.5">
                View ventures
              </a>
              <a href="https://urhermes.com/" class="rounded-full border border-black/10 bg-white px-6 py-3 text-sm font-bold text-[#171717] transition hover:-translate-y-0.5 hover:border-black/20">
                Explore YourHermes
              </a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-black/10 bg-white/72 p-5 shadow-2xl shadow-black/[0.06] backdrop-blur">
            <div class="grid gap-3">
              <div class="rounded-[1.5rem] bg-[#171717] p-6 text-white">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-white/50">Current portfolio</p>
                <div class="mt-6 grid grid-cols-2 gap-3">
                  <div>
                    <p class="text-4xl font-black">4</p>
                    <p class="text-sm text-white/55">active ventures</p>
                  </div>
                  <div>
                    <p class="text-4xl font-black">2</p>
                    <p class="text-sm text-white/55">live domains</p>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                {ventures.map((venture) => (
                  <a href={venture.url} class="group rounded-3xl border border-black/8 bg-white p-5 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-black/[0.06]">
                    <div class="mb-6 h-2 w-12 rounded-full" style={`background:${venture.accent}`}></div>
                    <p class="text-lg font-black tracking-tight text-[#171717]">{venture.name}</p>
                    <p class="mt-1 text-xs font-bold uppercase tracking-[0.16em] text-[#8A8176]">{venture.tag}</p>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="ventures" class="border-y border-black/5 bg-white py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-14 flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.24em] text-[#C2410C]">Active ventures</p>
            <h2 class="mt-3 max-w-3xl text-4xl font-black tracking-[-0.04em] text-[#171717] md:text-6xl">
              What’s being built right now.
            </h2>
          </div>
          <p class="max-w-md text-base leading-7 text-[#6B655D]">
            Each project is at a different stage, but the standard is the same: shipped software, clear positioning, and proof from actual use.
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-2">
          {ventures.map((venture) => (
            <article class="group rounded-[2rem] border border-black/10 bg-[#FAF9F6] p-7 transition hover:-translate-y-1 hover:bg-white hover:shadow-2xl hover:shadow-black/[0.06]">
              <div class="mb-8 flex items-start justify-between gap-6">
                <div>
                  <div class="mb-4 inline-flex rounded-full border border-black/10 bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-[#6B655D]">
                    {venture.status}
                  </div>
                  <h3 class="text-3xl font-black tracking-[-0.035em] text-[#171717] md:text-4xl">{venture.name}</h3>
                  <p class="mt-2 text-sm font-bold uppercase tracking-[0.18em] text-[#8A8176]">{venture.tag}</p>
                </div>
                <div class="h-14 w-14 shrink-0 rounded-2xl" style={`background:${venture.accent}`}></div>
              </div>

              <p class="text-lg leading-8 text-[#5F5A52]">{venture.description}</p>

              <ul class="mt-8 grid gap-3">
                {venture.proof.map((item) => (
                  <li class="flex items-center gap-3 text-sm font-semibold text-[#3F3A34]">
                    <span class="h-2 w-2 rounded-full" style={`background:${venture.accent}`}></span>
                    {item}
                  </li>
                ))}
              </ul>

              <a href={venture.url} class="mt-8 inline-flex items-center gap-2 text-sm font-black text-[#171717] transition group-hover:gap-3">
                Open project
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="thesis" class="py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.24em] text-[#C2410C]">Operating thesis</p>
            <h2 class="mt-3 text-4xl font-black tracking-[-0.04em] text-[#171717] md:text-6xl">
              Small bets, real feedback, compounding proof.
            </h2>
          </div>
          <div class="grid gap-4">
            {principles.map((principle, index) => (
              <div class="rounded-3xl border border-black/10 bg-white/70 p-6 shadow-sm">
                <p class="mb-3 text-xs font-black uppercase tracking-[0.22em] text-[#A29A90]">0{index + 1}</p>
                <p class="text-xl font-bold leading-8 tracking-[-0.02em] text-[#26221E]">{principle}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#171717] py-20 text-white">
      <div class="mx-auto flex max-w-7xl flex-col justify-between gap-8 px-6 lg:flex-row lg:items-center">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.24em] text-white/40">Newest venture</p>
          <h2 class="mt-3 max-w-3xl text-4xl font-black tracking-[-0.04em] md:text-6xl">YourHermes is live.</h2>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-white/62">
            A dedicated service for setting up private AI operators with workflow discovery, trust boundaries, and approval-gated execution.
          </p>
        </div>
        <a href="https://urhermes.com/" class="inline-flex shrink-0 items-center justify-center rounded-full bg-white px-7 py-4 text-sm font-black text-[#171717] transition hover:-translate-y-0.5">
          Visit urhermes.com →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
