---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'Live product',
    category: 'Shared finance',
    url: 'https://useflowt.app/',
    accent: '#3A5C77',
    description: 'Shared budgeting for couples, roommates, trips, and households — built around clear balances, receipt capture, and settlement that people can actually trust.',
    proof: ['Budget Spaces', 'Group settlement', 'Receipt scan', 'AI assistant'],
    signal: 'iOS + Android path'
  },
  {
    name: 'OnlyPets',
    status: 'Production API',
    category: 'Consumer social',
    url: 'https://api.gary-yong.com/pets/health',
    accent: '#B88A3D',
    description: 'A pet-focused social platform with profiles, posts, friends, messaging, a digital store, and a playful in-app economy.',
    proof: ['Social feed', 'Owner + pet DMs', 'Nibbles economy', 'Digital store'],
    signal: 'TestFlight track'
  },
  {
    name: 'NEON 777',
    status: 'Live web platform',
    category: 'Gaming systems',
    url: 'https://gary-yong.com/casino.html',
    accent: '#7C3AED',
    description: 'A browser gaming platform with casino games, poker, achievements, leaderboards, CS2 betting, and account-level history.',
    proof: ['7 games', 'Socket.io poker', 'CS2 betting', 'Bet history'],
    signal: 'Live on web'
  },
  {
    name: 'YourHermes',
    status: 'Service venture',
    category: 'Private AI operators',
    url: 'https://urhermes.com/',
    accent: '#3FB950',
    description: 'A productized setup service for private AI operators: workflow discovery, Hermes configuration, approval gates, memory, and handoff.',
    proof: ['Workflow audit', 'Hermes setup', 'Approval gates', 'Private operator'],
    signal: 'urhermes.com'
  }
];

const standards = [
  ['01', 'Working systems first', 'YongAI starts with usable products and real workflows, then turns repeated patterns into sharper ventures or services.'],
  ['02', 'Operator discipline', 'Every project is treated like a live system: clear scope, deployment hygiene, verification, and maintainable handoff.'],
  ['03', 'AI without theatre', 'AI is used where it improves the workflow. No robot mascots, vague magic, or “future of everything” copy.'],
  ['04', 'Trust as design material', 'Privacy, approval gates, source-grounded outputs, and calm UX are part of the product — not an afterthought.']
];
---

<Layout
  title="YongAI — Practical ventures, built with operator discipline"
  description="YongAI is Gary Yong’s venture portfolio and applied AI studio: shipping practical products, validating workflow ideas, and turning useful patterns into services and companies."
  ogImage="https://yongai.ca/brand/YongAI_website_header_black_on_light_2400x600.png"
>
  <main class="brand-page">
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="/" class="brand-link" aria-label="YongAI home">
        <img src="/brand/YongAI_header_cropped.svg" alt="YongAI" />
      </a>
      <div class="nav-links">
        <a href="#portfolio">Portfolio</a>
        <a href="#method">Method</a>
        <a href="#standards">Standards</a>
        <a href="https://urhermes.com/">YourHermes</a>
      </div>
    </nav>

    <section class="hero-section">
      <div class="hero-copy">
        <p class="eyebrow">YongAI / venture portfolio</p>
        <h1><span>Practical</span><span>ventures.</span><span>Operator discipline.</span></h1>
        <p class="hero-sub">
          A portfolio of working products, applied AI experiments, and service playbooks — built from real workflows rather than pitch-deck abstractions.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="button primary">View the portfolio</a>
          <a href="https://urhermes.com/" class="button secondary">Explore YourHermes</a>
        </div>
      </div>

      <aside class="portfolio-panel" aria-label="YongAI portfolio summary">
        <div class="panel-card panel-card-main">
          <span class="panel-label">Portfolio system</span>
          <strong>Working products, reviewed like live operations.</strong>
          <p>Four active ventures across finance, consumer social, gaming, and private AI operators.</p>
        </div>
        <div class="panel-card-grid">
          <div><span>01</span><strong>Ship</strong><small>usable systems</small></div>
          <div><span>02</span><strong>Verify</strong><small>real workflows</small></div>
          <div><span>03</span><strong>Package</strong><small>repeatable offers</small></div>
        </div>
      </aside>
    </section>

    <section class="proof-strip" aria-label="Portfolio summary">
      <div>
        <strong>4</strong>
        <span>active ventures</span>
      </div>
      <div>
        <strong>Live</strong>
        <span>web + mobile systems</span>
      </div>
      <div>
        <strong>Toronto</strong>
        <span>operator-led studio</span>
      </div>
      <div>
        <strong>AI</strong>
        <span>where workflow value is real</span>
      </div>
    </section>

    <section id="portfolio" class="portfolio-section">
      <div class="section-kicker">
        <p class="eyebrow">Current portfolio</p>
        <h2>Products, services, and experiments with usage behind them.</h2>
      </div>

      <div class="venture-board">
        {ventures.map((venture, index) => (
          <article class={`venture-card card-${index + 1}`} style={`--accent:${venture.accent}`}>
            <div class="card-index">0{index + 1}</div>
            <div class="card-main">
              <div class="card-topline">
                <span>{venture.category}</span>
                <em>{venture.status}</em>
              </div>
              <h3>{venture.name}</h3>
              <p>{venture.description}</p>
            </div>
            <div class="card-footer">
              <div class="proof-tags">
                {venture.proof.map((item) => <span>{item}</span>)}
              </div>
              <a href={venture.url}>Open project →</a>
            </div>
            <div class="signal-dot" aria-hidden="true"></div>
            <small>{venture.signal}</small>
          </article>
        ))}
      </div>
    </section>

    <section id="method" class="method-section">
      <div class="method-visual" aria-hidden="true">
        <div class="method-map">
          <span>Workflow</span>
          <i></i>
          <span>Prototype</span>
          <i></i>
          <span>Proof</span>
          <i></i>
          <span>Playbook</span>
        </div>
      </div>
      <div class="method-copy">
        <p class="eyebrow">Operating method</p>
        <h2>Build the proof. Extract the playbook. Ship the next version.</h2>
        <p>
          YongAI is intentionally not a generic AI shop. The work starts with concrete products and workflow problems, then sharpens into repeatable systems: apps, automations, demos, private operators, and venture experiments.
        </p>
        <div class="method-steps">
          <div><span>Discover</span><strong>Find the workflow that is actually painful.</strong></div>
          <div><span>Prototype</span><strong>Build a usable system, not a slide.</strong></div>
          <div><span>Verify</span><strong>Test locally, deploy carefully, measure the result.</strong></div>
          <div><span>Package</span><strong>Turn repeated wins into a product or service.</strong></div>
        </div>
      </div>
    </section>

    <section id="standards" class="standards-section">
      <div class="section-kicker compact">
        <p class="eyebrow">Brand standards</p>
        <h2>Calm, useful, and credible.</h2>
      </div>
      <div class="standards-grid">
        {standards.map(([number, title, body]) => (
          <article>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div>
        <p class="eyebrow">Next venture</p>
        <h2>Useful systems beat loud promises.</h2>
      </div>
      <div class="cta-actions">
        <a href="https://www.linkedin.com/in/gary-yong-66a9ba164" class="button primary">Connect with Gary</a>
        <a href="/brand/YongAI_brand_guide.html" class="button secondary">View brand guide</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) {
    margin: 0;
    background: #f5f1e8;
  }

  :global(*) { box-sizing: border-box; }

  .brand-page {
    min-height: 100vh;
    overflow-x: hidden;
    color: #0b0b0a;
    background:
      radial-gradient(circle at 75% 12%, rgba(184, 138, 61, 0.14), transparent 34rem),
      linear-gradient(180deg, #fffdf8 0%, #f5f1e8 42%, #eee7db 100%);
  }

  .site-nav,
  .hero-section,
  .proof-strip,
  .portfolio-section,
  .method-section,
  .standards-section,
  .cta-section {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    backdrop-filter: blur(22px);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    width: clamp(168px, 14vw, 188px);
    text-decoration: none;
  }

  .brand-link img {
    display: block;
    width: 100%;
    height: auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    font-size: 13px;
    font-weight: 760;
    letter-spacing: -.01em;
  }

  .nav-links a {
    color: #625d54;
    text-decoration: none;
  }

  .nav-links a:hover { color: #0b0b0a; }

  .hero-section {
    min-height: calc(100vh - 84px);
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, .68fr);
    align-items: center;
    gap: clamp(36px, 5vw, 64px);
    padding-block: 56px 86px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: #746b5d;
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  h1, h2, h3, p { margin-top: 0; }

  h1 {
    max-width: 820px;
    margin-bottom: 24px;
    color: #0b0b0a;
    font-size: clamp(58px, 8.5vw, 112px);
    line-height: .88;
    font-weight: 900;
    letter-spacing: -.082em;
  }

  h1 span { display: block; }

  .hero-copy { min-width: 0; }

  .hero-sub {
    max-width: min(680px, 100%);
    margin-bottom: 34px;
    color: #4f4a43;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.62;
    overflow-wrap: break-word;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 21px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 850;
    text-decoration: none;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .button:hover { transform: translateY(-2px); }

  .button.primary {
    color: #fffdf8;
    background: #0b0b0a;
    box-shadow: 0 18px 38px rgba(11, 11, 10, .16);
  }

  .button.secondary {
    color: #0b0b0a;
    background: rgba(255, 253, 248, .64);
    border: 1px solid rgba(11, 11, 10, .13);
  }

  .portfolio-panel {
    display: grid;
    gap: 16px;
    align-self: center;
  }

  .panel-card,
  .panel-card-grid div {
    border: 1px solid rgba(11, 11, 10, .11);
    background: rgba(255, 253, 248, .72);
    box-shadow: 0 24px 60px rgba(36, 30, 23, .08);
  }

  .panel-card-main {
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding: 32px;
    border-radius: 34px;
    background:
      linear-gradient(135deg, rgba(255, 253, 248, .9), rgba(245, 241, 232, .78)),
      repeating-linear-gradient(90deg, rgba(11,11,10,.04) 0 1px, transparent 1px 44px),
      repeating-linear-gradient(0deg, rgba(11,11,10,.03) 0 1px, transparent 1px 44px);
  }

  .panel-label {
    width: fit-content;
    margin-bottom: auto;
    padding: 8px 10px;
    border: 1px solid rgba(11, 11, 10, .10);
    border-radius: 999px;
    color: #746b5d;
    background: rgba(255,253,248,.68);
    font-size: 11px;
    font-weight: 860;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .panel-card-main strong {
    max-width: 360px;
    margin-bottom: 16px;
    color: #0b0b0a;
    font-size: clamp(30px, 3vw, 44px);
    line-height: .98;
    letter-spacing: -.055em;
  }

  .panel-card-main p {
    max-width: 390px;
    margin-bottom: 0;
    color: #5c554b;
    font-size: 15px;
    line-height: 1.55;
  }

  .panel-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .panel-card-grid div {
    min-height: 128px;
    padding: 18px;
    border-radius: 22px;
  }

  .panel-card-grid span,
  .panel-card-grid strong,
  .panel-card-grid small { display: block; }

  .panel-card-grid span {
    margin-bottom: 22px;
    color: #b88a3d;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .14em;
  }

  .panel-card-grid strong {
    margin-bottom: 4px;
    color: #0b0b0a;
    font-size: 18px;
    letter-spacing: -.035em;
  }

  .panel-card-grid small {
    color: #746b5d;
    font-size: 12px;
    font-weight: 720;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 28px;
    overflow: hidden;
    background: #0b0b0a;
  }

  .proof-strip div {
    min-height: 128px;
    padding: 24px;
    border-right: 1px solid rgba(255, 253, 248, .14);
  }

  .proof-strip div:last-child { border-right: 0; }

  .proof-strip strong,
  .proof-strip span { display: block; }

  .proof-strip strong {
    margin-bottom: 10px;
    color: #fffdf8;
    font-size: clamp(28px, 4vw, 46px);
    line-height: .95;
    letter-spacing: -.055em;
  }

  .proof-strip span {
    color: rgba(255, 253, 248, .58);
    font-size: 13px;
    font-weight: 700;
  }

  .portfolio-section,
  .standards-section { padding-block: 100px; }

  .section-kicker {
    display: grid;
    grid-template-columns: .66fr 1fr;
    gap: 44px;
    align-items: end;
    margin-bottom: 34px;
  }

  .section-kicker.compact {
    max-width: 780px;
    display: block;
  }

  .section-kicker h2,
  .method-copy h2,
  .cta-section h2 {
    margin: 0;
    color: #0b0b0a;
    font-size: clamp(38px, 5.8vw, 68px);
    line-height: .94;
    font-weight: 900;
    letter-spacing: -.065em;
  }

  .venture-board {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 18px;
  }

  .venture-card {
    position: relative;
    min-height: 430px;
    grid-column: span 6;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 28px;
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 30px;
    background: rgba(255, 253, 248, .74);
    box-shadow: 0 20px 50px rgba(36, 30, 23, .06);
  }

  .venture-card.card-1 { grid-column: span 7; }
  .venture-card.card-2 { grid-column: span 5; }
  .venture-card.card-3 { grid-column: span 5; }
  .venture-card.card-4 { grid-column: span 7; background: #11110f; color: #fffdf8; }

  .venture-card::before {
    content: '';
    position: absolute;
    inset: auto -40px -70px auto;
    width: 260px;
    height: 260px;
    border: 1px solid color-mix(in srgb, var(--accent) 42%, transparent);
    transform: rotate(24deg);
    opacity: .42;
  }

  .card-index {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    color: #fffdf8;
    background: #0b0b0a;
    font-weight: 850;
    letter-spacing: -.04em;
  }

  .card-4 .card-index { background: #fffdf8; color: #0b0b0a; }

  .card-main { margin-top: 54px; position: relative; z-index: 1; }

  .card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .card-topline span,
  .card-topline em,
  .venture-card small {
    color: #82796b;
    font-size: 11px;
    font-style: normal;
    font-weight: 860;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .card-4 .card-topline span,
  .card-4 .card-topline em,
  .card-4 small { color: rgba(255,253,248,.56); }

  .venture-card h3 {
    margin: 0 0 18px;
    color: inherit;
    font-size: clamp(38px, 5vw, 60px);
    line-height: .92;
    font-weight: 900;
    letter-spacing: -.07em;
  }

  .venture-card p {
    max-width: 620px;
    margin-bottom: 0;
    color: #4b463e;
    font-size: 17px;
    line-height: 1.62;
  }

  .card-4 p { color: rgba(255,253,248,.68); }

  .card-footer {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-top: auto;
    padding-top: 34px;
  }

  .proof-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .proof-tags span {
    padding: 8px 10px;
    border: 1px solid rgba(11, 11, 10, .10);
    border-radius: 999px;
    color: #312d28;
    background: rgba(255, 253, 248, .72);
    font-size: 12px;
    font-weight: 760;
  }

  .card-4 .proof-tags span {
    color: rgba(255,253,248,.88);
    border-color: rgba(255,253,248,.14);
    background: rgba(255,253,248,.08);
  }

  .card-footer a {
    flex: 0 0 auto;
    color: inherit;
    font-size: 14px;
    font-weight: 860;
    text-decoration: none;
  }

  .card-footer a:hover { color: var(--accent); }

  .signal-dot {
    position: absolute;
    right: 26px;
    top: 26px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--accent) 16%, transparent);
  }

  .venture-card small {
    display: none;
  }

  .method-section {
    display: grid;
    grid-template-columns: .75fr 1fr;
    gap: 18px;
    padding-bottom: 100px;
  }

  .method-visual,
  .method-copy {
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 30px;
    background: rgba(255,253,248,.68);
  }

  .method-visual {
    min-height: 560px;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 36px;
    background:
      radial-gradient(circle at 30% 20%, rgba(63,185,80,.18), transparent 18rem),
      repeating-linear-gradient(135deg, rgba(255,253,248,.07) 0 1px, transparent 1px 36px),
      #0b0b0a;
  }

  .method-map {
    width: min(100%, 360px);
    display: grid;
    gap: 14px;
  }

  .method-map span {
    display: block;
    padding: 18px 20px;
    border: 1px solid rgba(255,253,248,.16);
    border-radius: 18px;
    color: #fffdf8;
    background: rgba(255,253,248,.08);
    font-size: 15px;
    font-weight: 850;
    letter-spacing: -.02em;
  }

  .method-map i {
    width: 1px;
    height: 26px;
    margin-left: 22px;
    background: rgba(255,253,248,.24);
  }

  .method-copy {
    padding: 42px;
  }

  .method-copy p {
    max-width: 680px;
    margin: 24px 0 34px;
    color: #4f4a43;
    font-size: 18px;
    line-height: 1.72;
  }

  .method-steps {
    display: grid;
    gap: 10px;
  }

  .method-steps div {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 18px;
    align-items: center;
    padding: 16px 0;
    border-top: 1px solid rgba(11, 11, 10, .10);
  }

  .method-steps span {
    color: #82796b;
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .method-steps strong {
    color: #0b0b0a;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -.025em;
  }

  .standards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .standards-grid article {
    min-height: 280px;
    padding: 24px;
    border: 1px solid rgba(11, 11, 10, .12);
    border-radius: 26px;
    background: rgba(255,253,248,.64);
  }

  .standards-grid span {
    display: block;
    margin-bottom: 52px;
    color: #b88a3d;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .16em;
  }

  .standards-grid h3 {
    margin-bottom: 16px;
    color: #0b0b0a;
    font-size: 24px;
    line-height: 1.02;
    letter-spacing: -.04em;
  }

  .standards-grid p {
    color: #5c554b;
    font-size: 15px;
    line-height: 1.58;
  }

  .cta-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
    margin-bottom: 100px;
    padding: 34px;
    border-radius: 30px;
    color: #fffdf8;
    background: #0b0b0a;
  }

  .cta-section .eyebrow { color: rgba(255,253,248,.48); }
  .cta-section h2 { color: #fffdf8; max-width: 760px; }
  .cta-section .button.primary { color: #0b0b0a; background: #fffdf8; }
  .cta-section .button.secondary { color: #fffdf8; background: rgba(255,253,248,.08); border-color: rgba(255,253,248,.16); }

  @media (max-width: 920px) {
    .nav-links { display: none; }
    .hero-section,
    .section-kicker,
    .method-section,
    .cta-section {
      grid-template-columns: 1fr;
    }
    .hero-section { min-height: 0; padding-block: 44px 72px; }
