---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import SiteNav from '../components/SiteNav.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'LIVE PRODUCT · SHARED FINANCE',
    category: 'Shared finance',
    url: 'https://useflowt.app/',
    logo: '/portfolio/logos/flowt.svg',
    logoAlt: 'Flowt app icon',
    description: 'Shared budgeting for couples, roommates, trips, and households — balances, receipts, and settlement in one trusted workspace.',
    proof: ['Budget Spaces', 'Receipt scan', 'Settlement', 'AI assistant'],
  },
  {
    name: 'OnlyPets',
    status: 'IN TESTFLIGHT · PET SOCIAL',
    category: 'Pet social app',
    url: '/onlypets/',
    logo: '/portfolio/logos/onlypets.png',
    logoAlt: 'OnlyPets app icon',
    description: 'A pet-owner community for profiles, posts, messages, product discovery, and a playful in-app Nibbles economy.',
    proof: ['Feed', 'Pet profiles', 'Messages', 'Pet Store'],
  },
  {
    name: 'Cue',
    status: 'IN TESTFLIGHT · VOICE AI',
    category: 'Meeting assistant',
    url: '/cue/',
    logo: '/portfolio/logos/cue-web.png',
    logoAlt: 'Cue app icon',
    description: 'A private voice meeting assistant that turns conversations into debriefs, actions, insights, and a clear next move.',
    proof: ['Voice capture', 'Structured debrief', 'Ask Cue', 'TestFlight'],
  },
  {
    name: 'NEON 777',
    status: 'LIVE WEB PLATFORM · GAMING',
    category: 'Gaming systems',
    url: 'https://gary-yong.com/casino.html',
    logo: '/portfolio/logos/neon777.svg',
    logoAlt: 'NEON 777 logo',
    description: 'Browser-based gaming with casino titles, poker, achievements, leaderboards, CS2 betting, and account-level history.',
    proof: ['7 games', 'Poker', 'CS2 betting', 'Bet history'],
  },
  {
    name: 'YourHermes',
    status: 'SERVICE VENTURE · AI OPERATORS',
    category: 'Private AI operators',
    url: 'https://urhermes.com/',
    logo: '/portfolio/logos/yourhermes.png',
    logoAlt: 'YourHermes icon',
    description: 'A productized setup service for private AI operators — discovery, Hermes configuration, approval gates, memory, and handoff.',
    proof: ['Workflow audit', 'Hermes setup', 'Approval gates', 'Handoff'],
    dark: true,
  },
];

const metrics = [
  ['5', 'venture tracks in active portfolio'],
  ['2', 'live products already in market'],
  ['1', 'TestFlight product in active testing'],
];

const approach = [
  ['01', 'Start with a narrow use case', 'Define the user, the job, and the smallest surface that can prove demand.'],
  ['02', 'Build with AI-assisted execution', 'Use agentic development where it speeds up implementation, testing, and iteration — not as marketing theatre.'],
  ['03', 'Ship, test, and decide', 'Move quickly to a working product, then use real feedback to continue, reposition, or stop.'],
];
---

<Layout
  title="YongAI — Useful software, built fast"
  description="YongAI builds focused software ventures and AI-enabled workflows using small-team execution, applied AI tooling, and testing discipline."
  ogImage="https://yongai.ca/brand/v3/YongAI_website_header_black_on_light_2400x600.png"
>
  <main class="brand-page">
    <SiteNav />

    <section class="hero-section">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">Venture product studio</p>
        <h1>We build useful software fast.</h1>
        <p class="hero-sub">
          YongAI builds focused software ventures and AI-enabled workflows using small-team execution, applied AI tooling, and testing discipline. We move from idea to usable proof without long roadmap cycles.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="button primary">View portfolio</a>
          <a href="mailto:gary.yong@yongai.ca" class="button secondary">gary.yong@yongai.ca</a>
        </div>
      </div>

      <aside class="snapshot-card" aria-label="YongAI by the numbers" data-reveal style="--reveal-delay: 90ms">
        <p class="eyebrow">By the numbers</p>
        <h2>Small portfolio. Real surfaces.</h2>
        <div class="snapshot-list metric-list">
          {metrics.map(([value, label]) => (
            <div>
              <strong>{value}</strong>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </aside>
    </section>

    <section id="portfolio" class="portfolio-section">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Featured ventures</p>
        <h2>Products with a clear job to do.</h2>
      </div>

      <div class="venture-board">
        {ventures.map((venture, index) => (
          <article class={`venture-card ${venture.dark ? 'dark' : ''}`} data-reveal style={`--reveal-delay: ${(index % 2) * 70}ms`}>
            <div class="card-head">
              <div class="venture-logo" aria-label={`${venture.name} logo`}>
                <img src={venture.logo} alt={venture.logoAlt} loading="lazy" />
              </div>
              <em>{venture.status}</em>
            </div>
            <p class="card-category">{venture.category}</p>
            <h3>{venture.name}</h3>
            <p>{venture.description}</p>
            <div class="proof-tags">
              {venture.proof.map((item) => <span>{item}</span>)}
            </div>
            <a class="project-link" href={venture.url}>Open project →</a>
          </article>
        ))}
      </div>
    </section>

    <section id="method" class="method-section">
      <div class="section-header narrow" data-reveal>
        <p class="eyebrow">How we build</p>
        <h2>AI-assisted development, operator-grade discipline.</h2>
      </div>
      <div class="approach-grid">
        {approach.map(([number, title, body], index) => (
          <article data-reveal style={`--reveal-delay: ${index * 70}ms`}>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section" data-reveal>
      <div>
        <p class="eyebrow">Contact</p>
        <h2>Have a focused product or workflow worth proving?</h2>
      </div>
      <div class="cta-actions">
        <a href="https://www.linkedin.com/in/gary-yong-66a9ba164" class="button primary">Connect with Gary</a>
        <a href="mailto:gary.yong@yongai.ca" class="button secondary">Email YongAI</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) { margin: 0; background: #FAF8F2; }
  :global(*) { box-sizing: border-box; }

  .brand-page {
    min-height: 100vh;
    overflow-x: hidden;
    color: #000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: linear-gradient(180deg, #FFFFFF 0%, #FAF8F2 42%, #FAF8F2 100%);
  }

  .hero-section, .portfolio-section, .method-section, .cta-section {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
  }

  h1, h2, h3, p { margin-top: 0; }
  h1, h2, h3 { font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; }
  .eyebrow { margin: 0 0 14px; color: #555; font-size: 12px; font-weight: 850; letter-spacing: .18em; text-transform: uppercase; }

  .hero-section {
    min-height: calc(86vh - 78px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 430px);
    align-items: center;
    gap: clamp(34px, 5vw, 72px);
    padding-block: 40px 54px;
  }

  h1 { max-width: 780px; margin-bottom: 20px; font-size: clamp(58px, 7vw, 96px); line-height: .96; font-weight: 700; letter-spacing: -.025em; }
  .hero-sub { max-width: 640px; margin-bottom: 28px; color: #2F2F2F; font-size: clamp(18px, 2vw, 22px); line-height: 1.58; }

  .button, .project-link {
    display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; text-decoration: none; font-weight: 850; transition: transform var(--motion-base) var(--motion-ease), box-shadow var(--motion-base) var(--motion-ease), background var(--motion-fast) ease, color var(--motion-fast) ease, border-color var(--motion-fast) ease;
  }
  .button { min-height: 48px; padding: 0 21px; font-size: 14px; }
  .button.primary { color: #fff; background: #000; box-shadow: 0 18px 38px rgba(0,0,0,.16); }
  .button.secondary { color: #000; background: rgba(255,255,255,.64); border: 1px solid rgba(0,0,0,.13); }
  .button:hover, .button:focus-visible, .project-link:hover, .project-link:focus-visible { transform: translateY(-2px); }
  .button:active, .project-link:active { transform: translateY(0) scale(.985); }
  .hero-actions, .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; }

  .snapshot-card {
    padding: 28px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 22px;
    background: rgba(255,255,255,.72);
    box-shadow: 0 24px 70px rgba(36,30,23,.08);
    transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease);
  }
  .snapshot-card:hover { transform: translateY(-3px); border-color: rgba(0,0,0,.2); box-shadow: 0 30px 78px rgba(36,30,23,.11); }
  .snapshot-card h2 { margin: 0 0 22px; font-size: clamp(30px, 3vw, 42px); line-height: 1.05; font-weight: 650; }
  .snapshot-list { display: grid; gap: 0; border-top: 1px solid rgba(0,0,0,.1); }
  .snapshot-list a,
  .metric-list div { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding: 16px 0; border-bottom: 1px solid rgba(0,0,0,.1); color: #000; text-decoration: none; }
  .snapshot-list span { font-weight: 850; }
  .snapshot-list em { color: #555; font-size: 12px; font-style: normal; font-weight: 780; text-transform: uppercase; letter-spacing: .11em; text-align: right; }
  .metric-list strong { font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; font-size: 42px; line-height: .9; }
  .metric-list span { max-width: 230px; color: #555; font-size: 13px; font-weight: 760; line-height: 1.3; text-align: right; }

  .portfolio-section, .method-section { padding-block: 64px; }
  .section-header { display: flex; align-items: end; justify-content: space-between; gap: 32px; margin-bottom: 24px; }
  .section-header.narrow { max-width: 760px; display: block; }
  .section-header h2 { max-width: 720px; margin: 0; font-size: clamp(32px, 4vw, 52px); line-height: 1.05; font-weight: 640; letter-spacing: -.015em; }

  .venture-board { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
  .venture-card {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    padding: 26px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 22px;
    background: rgba(255,255,255,.72);
    box-shadow: 0 18px 46px rgba(36,30,23,.055);
    transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease);
  }
  .venture-card:hover, .venture-card:focus-within { transform: translateY(-4px); border-color: rgba(0,0,0,.24); box-shadow: 0 28px 70px rgba(36,30,23,.12); }
  .venture-card.dark { color: #fff; background: #0B0C0E; }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 42px; }
  .venture-logo { width: 64px; height: 64px; display: grid; place-items: center; flex: 0 0 auto; border: 1px solid rgba(0,0,0,.10); border-radius: 18px; background: #fff; box-shadow: 0 12px 30px rgba(36,30,23,.08); overflow: hidden; }
  .venture-card .venture-logo img { width: 100% !important; height: 100% !important; min-height: 0 !important; max-width: 100%; max-height: 100%; object-fit: contain !important; filter: none !important; display: block; }
  .dark .venture-logo { border-color: rgba(255,255,255,.18); background: rgba(255,255,255,.08); }
  .card-head em, .card-category { color: #555; font-size: 11px; font-style: normal; font-weight: 860; letter-spacing: .14em; text-transform: uppercase; text-align: right; }
  .dark .card-head em, .dark .card-category { color: rgba(255,255,255,.56); }
  .card-category { margin-bottom: 14px; }
  .venture-card h3 { margin: 0 0 14px; font-size: clamp(34px, 4vw, 50px); line-height: 1.02; font-weight: 710; letter-spacing: -.018em; }
  .venture-card p { max-width: 620px; margin: 0 0 22px; color: #2F2F2F; font-size: 16px; line-height: 1.56; }
  .dark p { color: rgba(255,255,255,.68); }
  .proof-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; padding-right: 176px; }
  .proof-tags span { padding: 7px 10px; border: 1px solid rgba(0,0,0,.10); border-radius: 999px; color: #000; background: rgba(255,255,255,.72); font-size: 12px; font-weight: 760; }
  .dark .proof-tags span { color: rgba(255,255,255,.88); border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.08); }
  .project-link {
    align-self: flex-end;
    width: 156px;
    height: 44px;
    margin-top: -44px;
    border: 1px solid rgba(0,0,0,.13);
    color: #000;
    background: rgba(255,255,255,.72);
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }
  .venture-card:hover .project-link, .venture-card:focus-within .project-link { transform: scale(1.06); color: #fff; background: #000; box-shadow: 0 14px 32px rgba(0,0,0,.16); }
  .dark .project-link { color: #fff; border-color: rgba(255,255,255,.16); background: rgba(255,255,255,.08); }
  .dark:hover .project-link, .dark:focus-within .project-link { color: #000; background: #fff; }

  .approach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .approach-grid article { min-height: 230px; padding: 24px; border: 1px solid rgba(0,0,0,.12); border-radius: 18px; background: rgba(255,255,255,.66); transition: transform var(--motion-base) var(--motion-ease), border-color var(--motion-fast) ease, box-shadow var(--motion-base) var(--motion-ease), background-color var(--motion-fast) ease; }
  .approach-grid article:hover { transform: translateY(-3px); border-color: rgba(0,0,0,.21); background: rgba(255,255,255,.9); box-shadow: 0 18px 46px rgba(36,30,23,.07); }
  .approach-grid span { display: block; margin-bottom: 42px; font-size: 12px; font-weight: 820; letter-spacing: .16em; }
  .approach-grid h3 { margin-bottom: 14px; font-size: 25px; line-height: 1.08; font-weight: 720; }
  .approach-grid p { color: #3B3B3B; font-size: 15px; line-height: 1.55; }

  .cta-section { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; margin: 48px auto 82px; padding: 32px; border-radius: 22px; color: #fff; background: #000; }
  .cta-section .eyebrow { color: rgba(255,255,255,.5); }
  .cta-section h2 { max-width: 760px; margin: 0; color: #fff; font-size: clamp(32px, 4vw, 52px); line-height: 1.06; font-weight: 640; }
  .cta-section .button.primary { color: #000; background: #fff; }
  .cta-section .button.secondary { color: #fff; background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.16); }

  @media (max-width: 920px) {
    .nav-links { display: none; }
    .mobile-menu { display: block; }
    .hero-section, .venture-board, .approach-grid, .cta-section { grid-template-columns: 1fr; }
    .hero-section { min-height: 0; padding-block: 38px 54px; }
    .section-header { display: block; }
    .proof-tags { padding-right: 0; }
    .project-link { align-self: flex-start; margin-top: 18px; }
  }

  @media (max-width: 560px) {
    .hero-section, .portfolio-section, .method-section, .cta-section { width: min(100% - 32px, 1180px); }
    .brand-link { width: 154px; }
    h1 { font-size: clamp(48px, 14vw, 64px); line-height: .98; }
    .portfolio-section, .method-section { padding-block: 44px; }
    .venture-card { min-height: 0; padding: 22px; }
    .cta-section { margin-bottom: 64px; padding: 26px; }
  }

  @media (hover: none) {
    .snapshot-card:hover, .venture-card:hover, .approach-grid article:hover { transform: none; }
  }
</style>
