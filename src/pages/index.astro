---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const ventures = [
  {
    name: 'Flowt',
    status: 'Live product',
    category: 'Shared finance',
    url: 'https://useflowt.app/',
    description: 'Shared budgeting for couples, roommates, trips, and households — with balances, receipts, and settlement built for trust.',
    proof: ['Budget Spaces', 'Receipt scan', 'Settlement', 'AI assistant'],
  },
  {
    name: 'OnlyPets',
    status: 'TestFlight testing',
    category: 'Pet social app',
    url: '/onlypets/',
    description: 'A playful mobile community for pet owners to post, message, discover products, and earn an in-app Nibbles economy.',
    proof: ['Feed', 'Pet profiles', 'Messages', 'Pet Store'],
  },
  {
    name: 'NEON 777',
    status: 'Live web platform',
    category: 'Gaming systems',
    url: 'https://gary-yong.com/casino.html',
    description: 'A browser gaming platform with casino games, poker, achievements, leaderboards, CS2 betting, and account history.',
    proof: ['7 games', 'Poker', 'CS2 betting', 'Bet history'],
  },
  {
    name: 'YourHermes',
    status: 'Service venture',
    category: 'Private AI operators',
    url: 'https://urhermes.com/',
    description: 'A productized setup service for private AI operators: workflow discovery, Hermes configuration, approval gates, memory, and handoff.',
    proof: ['Workflow audit', 'Hermes setup', 'Approval gates', 'Handoff'],
    dark: true,
  },
];

const approach = [
  ['01', 'Pick one real workflow', 'Start with a repeated pain point, user behavior, or market wedge — not a vague AI idea.'],
  ['02', 'Ship a visible proof', 'Build a product surface, demo, or service playbook that people can actually try.'],
  ['03', 'Decide the next move', 'Use traction, feedback, usage, or support load to decide whether to keep, cut, or scale.'],
];
---

<Layout
  title="YongAI — Build what proves it"
  description="YongAI builds focused software ventures and AI-enabled workflows with small-team speed, product discipline, and a bias toward working proof."
  ogImage="https://yongai.ca/brand/v3/YongAI_website_header_black_on_light_2400x600.png"
>
  <main class="brand-page">
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="/" class="brand-link" aria-label="YongAI home">
        <img src="/brand/v3/YongAI_horizontal_black_transparent.svg" alt="YongAI" />
      </a>
      <div class="nav-links">
        <a href="#portfolio">Portfolio</a>
        <a href="#method">Approach</a>
        <a href="/onlypets/">OnlyPets</a>
        <a href="https://urhermes.com/">YourHermes</a>
      </div>
      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span><span></span><span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href="#portfolio">Portfolio</a>
          <a href="#method">Approach</a>
          <a href="/onlypets/">OnlyPets</a>
          <a href="https://urhermes.com/">YourHermes</a>
        </div>
      </details>
    </nav>

    <section class="hero-section">
      <div class="hero-copy">
        <p class="eyebrow">YongAI / venture portfolio</p>
        <h1>Build what proves it.</h1>
        <p class="hero-sub">
          YongAI builds focused software ventures and AI-enabled workflows with small-team speed, product discipline, and a bias toward working proof.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="button primary">View portfolio</a>
          <a href="mailto:gary.yong@yongai.ca" class="button secondary">gary.yong@yongai.ca</a>
        </div>
      </div>

      <aside class="snapshot-card" aria-label="Portfolio snapshot">
        <p class="eyebrow">At a glance</p>
        <h2>Four active tracks.</h2>
        <div class="snapshot-list">
          {ventures.map((venture) => (
            <a href={venture.url}>
              <span>{venture.name}</span>
              <em>{venture.status}</em>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section id="portfolio" class="portfolio-section">
      <div class="section-header">
        <p class="eyebrow">Current portfolio</p>
        <h2>Working products, tested in public.</h2>
      </div>

      <div class="venture-board">
        {ventures.map((venture, index) => (
          <article class={`venture-card ${venture.dark ? 'dark' : ''}`}>
            <div class="card-head">
              <span>0{index + 1}</span>
              <em>{venture.status}</em>
            </div>
            <p class="card-category">{venture.category}</p>
            <h3>{venture.name}</h3>
            <p>{venture.description}</p>
            <div class="proof-tags">
              {venture.proof.map((item) => <span>{item}</span>)}
            </div>
            <a class="project-link" href={venture.url}>Open project →</a>
          </article>
        ))}
      </div>
    </section>

    <section id="method" class="method-section">
      <div class="section-header narrow">
        <p class="eyebrow">Approach</p>
        <h2>One cycle: find demand, ship proof, decide honestly.</h2>
      </div>
      <div class="approach-grid">
        {approach.map(([number, title, body]) => (
          <article>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div>
        <p class="eyebrow">Work with YongAI</p>
        <h2>Have a workflow or market worth proving?</h2>
      </div>
      <div class="cta-actions">
        <a href="https://www.linkedin.com/in/gary-yong-66a9ba164" class="button primary">Connect with Gary</a>
        <a href="mailto:gary.yong@yongai.ca" class="button secondary">Email YongAI</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  :global(body) { margin: 0; background: #FAF8F2; }
  :global(*) { box-sizing: border-box; }

  .brand-page {
    min-height: 100vh;
    overflow-x: hidden;
    color: #000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: linear-gradient(180deg, #FFFFFF 0%, #FAF8F2 42%, #FAF8F2 100%);
  }

  .site-nav, .hero-section, .portfolio-section, .method-section, .cta-section {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    backdrop-filter: blur(20px);
  }

  .brand-link { width: clamp(160px, 14vw, 186px); display: inline-flex; }
  .brand-link img { width: 100%; height: auto; display: block; }

  .nav-links { display: flex; align-items: center; gap: 26px; font-size: 13px; font-weight: 760; }
  .nav-links a { color: #3B3B3B; text-decoration: none; }
  .nav-links a:hover { color: #000; }

  .mobile-menu { display: none; position: relative; }
  .mobile-menu summary {
    width: 46px; height: 46px; display: grid; place-content: center; gap: 5px;
    border: 1px solid rgba(0,0,0,.14); border-radius: 999px; background: rgba(255,255,255,.72); cursor: pointer; list-style: none;
  }
  .mobile-menu summary::-webkit-details-marker { display: none; }
  .mobile-menu summary span { width: 18px; height: 2px; border-radius: 999px; background: #000; display: block; }
  .mobile-menu-panel {
    position: absolute; right: 0; top: calc(100% + 12px); min-width: 220px; padding: 10px;
    border: 1px solid rgba(0,0,0,.12); border-radius: 14px; background: rgba(255,255,255,.96); box-shadow: 0 24px 60px rgba(0,0,0,.12);
  }
  .mobile-menu-panel a { display: block; padding: 13px 14px; border-radius: 12px; color: #000; text-decoration: none; font-size: 15px; font-weight: 820; }
  .mobile-menu-panel a:hover { background: rgba(0,0,0,.055); }

  h1, h2, h3, p { margin-top: 0; }
  h1, h2, h3 { font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; }
  .eyebrow { margin: 0 0 14px; color: #555; font-size: 12px; font-weight: 850; letter-spacing: .18em; text-transform: uppercase; }

  .hero-section {
    min-height: calc(86vh - 78px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 430px);
    align-items: center;
    gap: clamp(34px, 5vw, 72px);
    padding-block: 40px 54px;
  }

  h1 { max-width: 780px; margin-bottom: 20px; font-size: clamp(58px, 7vw, 96px); line-height: .96; font-weight: 700; letter-spacing: -.025em; }
  .hero-sub { max-width: 640px; margin-bottom: 28px; color: #2F2F2F; font-size: clamp(18px, 2vw, 22px); line-height: 1.58; }

  .button, .project-link {
    display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; text-decoration: none; font-weight: 850; transition: transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
  }
  .button { min-height: 48px; padding: 0 21px; font-size: 14px; }
  .button.primary { color: #fff; background: #000; box-shadow: 0 18px 38px rgba(0,0,0,.16); }
  .button.secondary { color: #000; background: rgba(255,255,255,.64); border: 1px solid rgba(0,0,0,.13); }
  .button:hover, .project-link:hover { transform: translateY(-2px); }
  .hero-actions, .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; }

  .snapshot-card {
    padding: 28px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 22px;
    background: rgba(255,255,255,.72);
    box-shadow: 0 24px 70px rgba(36,30,23,.08);
  }
  .snapshot-card h2 { margin: 0 0 22px; font-size: clamp(30px, 3vw, 42px); line-height: 1.05; font-weight: 650; }
  .snapshot-list { display: grid; gap: 0; border-top: 1px solid rgba(0,0,0,.1); }
  .snapshot-list a { display: flex; justify-content: space-between; gap: 16px; padding: 16px 0; border-bottom: 1px solid rgba(0,0,0,.1); color: #000; text-decoration: none; }
  .snapshot-list span { font-weight: 850; }
  .snapshot-list em { color: #555; font-size: 12px; font-style: normal; font-weight: 780; text-transform: uppercase; letter-spacing: .11em; text-align: right; }

  .portfolio-section, .method-section { padding-block: 64px; }
  .section-header { display: flex; align-items: end; justify-content: space-between; gap: 32px; margin-bottom: 24px; }
  .section-header.narrow { max-width: 760px; display: block; }
  .section-header h2 { max-width: 720px; margin: 0; font-size: clamp(32px, 4vw, 52px); line-height: 1.05; font-weight: 640; letter-spacing: -.015em; }

  .venture-board { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
  .venture-card {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    padding: 26px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 22px;
    background: rgba(255,255,255,.72);
    box-shadow: 0 18px 46px rgba(36,30,23,.055);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  .venture-card:hover { transform: translateY(-4px); border-color: rgba(0,0,0,.24); box-shadow: 0 28px 70px rgba(36,30,23,.12); }
  .venture-card.dark { color: #fff; background: #0B0C0E; }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 46px; }
  .card-head span { width: 46px; height: 46px; display: grid; place-items: center; border-radius: 12px; color: #fff; background: #000; font-weight: 850; }
  .dark .card-head span { color: #000; background: #fff; }
  .card-head em, .card-category { color: #555; font-size: 11px; font-style: normal; font-weight: 860; letter-spacing: .14em; text-transform: uppercase; }
  .dark .card-head em, .dark .card-category { color: rgba(255,255,255,.56); }
  .card-category { margin-bottom: 14px; }
  .venture-card h3 { margin: 0 0 14px; font-size: clamp(34px, 4vw, 50px); line-height: 1.02; font-weight: 710; letter-spacing: -.018em; }
  .venture-card p { max-width: 620px; margin: 0 0 22px; color: #2F2F2F; font-size: 16px; line-height: 1.56; }
  .dark p { color: rgba(255,255,255,.68); }
  .proof-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; padding-right: 176px; }
  .proof-tags span { padding: 7px 10px; border: 1px solid rgba(0,0,0,.10); border-radius: 999px; color: #000; background: rgba(255,255,255,.72); font-size: 12px; font-weight: 760; }
  .dark .proof-tags span { color: rgba(255,255,255,.88); border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.08); }
  .project-link {
    align-self: flex-end;
    width: 156px;
    height: 44px;
    margin-top: -44px;
    border: 1px solid rgba(0,0,0,.13);
    color: #000;
    background: rgba(255,255,255,.72);
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }
  .venture-card:hover .project-link { transform: scale(1.06); color: #fff; background: #000; box-shadow: 0 14px 32px rgba(0,0,0,.16); }
  .dark .project-link { color: #fff; border-color: rgba(255,255,255,.16); background: rgba(255,255,255,.08); }
  .dark:hover .project-link { color: #000; background: #fff; }

  .approach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .approach-grid article { min-height: 230px; padding: 24px; border: 1px solid rgba(0,0,0,.12); border-radius: 18px; background: rgba(255,255,255,.66); }
  .approach-grid span { display: block; margin-bottom: 42px; font-size: 12px; font-weight: 820; letter-spacing: .16em; }
  .approach-grid h3 { margin-bottom: 14px; font-size: 25px; line-height: 1.08; font-weight: 720; }
  .approach-grid p { color: #3B3B3B; font-size: 15px; line-height: 1.55; }

  .cta-section { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; margin: 48px auto 82px; padding: 32px; border-radius: 22px; color: #fff; background: #000; }
  .cta-section .eyebrow { color: rgba(255,255,255,.5); }
  .cta-section h2 { max-width: 760px; margin: 0; color: #fff; font-size: clamp(32px, 4vw, 52px); line-height: 1.06; font-weight: 640; }
  .cta-section .button.primary { color: #000; background: #fff; }
  .cta-section .button.secondary { color: #fff; background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.16); }

  @media (max-width: 920px) {
    .nav-links { display: none; }
    .mobile-menu { display: block; }
    .hero-section, .venture-board, .approach-grid, .cta-section { grid-template-columns: 1fr; }
    .hero-section { min-height: 0; padding-block: 38px 54px; }
    .section-header { display: block; }
    .proof-tags { padding-right: 0; }
    .project-link { align-self: flex-start; margin-top: 18px; }
  }

  @media (max-width: 560px) {
    .site-nav, .hero-section, .portfolio-section, .method-section, .cta-section { width: min(100% - 32px, 1180px); }
    .brand-link { width: 154px; }
    h1 { font-size: clamp(48px, 14vw, 64px); line-height: .98; }
    .portfolio-section, .method-section { padding-block: 44px; }
    .venture-card { min-height: 0; padding: 22px; }
    .cta-section { margin-bottom: 64px; padding: 26px; }
  }
</style>
