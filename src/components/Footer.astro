---
// Footer — light theme
---

<footer class="border-t border-[rgba(0,0,0,0.08)] bg-[#F4F3EF] py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Brand -->
      <div class="flex items-center gap-2.5 font-bold text-lg">
        <div class="w-7 h-7 bg-[#C2410C] rounded-lg flex items-center justify-center">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 12 L8 4 L13 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="8" cy="4" r="1.5" fill="white"/>
          </svg>
        </div>
        <span class="text-[#1C1C1E]">Yong<span class="text-[#C2410C]">AI</span></span>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap items-center gap-6">
        <a href="#services" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">Services</a>
        <a href="#about" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">About</a>
        <a href="/responsible-ai" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">Responsible AI</a>
        <a href="#contact" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">Contact</a>
        <a href="https://www.linkedin.com/in/gary-yong-66a9ba164" target="_blank" rel="noopener" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">LinkedIn</a>
        <a href="mailto:gymoltbot@gmail.com" class="text-[#64748B] hover:text-[#1C1C1E] transition-colors duration-200 text-sm">gymoltbot@gmail.com</a>
      </div>

      <!-- Copyright -->
      <p class="text-[#94A3B8] text-sm order-first md:order-last">
        &copy; 2026 YongAI. Toronto, Canada.
      </p>
    </div>
  </div>
</footer>
