---
const navItems = [
  { label: 'Portfolio', href: '/#portfolio' },
  { label: 'Approach', href: '/#method' },
  { label: 'YourHermes', href: 'https://urhermes.com/' },
  { label: 'Contact', href: 'mailto:gary.yong@yongai.ca' },
];
---

<nav class="site-nav" aria-label="Primary navigation">
  <a href="/" class="brand-link" aria-label="YongAI home">
    <img src="/brand/v3/YongAI_horizontal_black_transparent.svg" alt="YongAI" />
  </a>
  <div class="nav-links">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </div>
  <details class="mobile-menu" data-mobile-menu>
    <summary aria-label="Open navigation menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </summary>
    <div class="mobile-menu-panel">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </details>
</nav>

<script>
  const menus = document.querySelectorAll<HTMLDetailsElement>('[data-mobile-menu]');

  menus.forEach((menu) => {
    if (menu.dataset.enhanced === 'true') return;
    menu.dataset.enhanced = 'true';

    const summary = menu.querySelector<HTMLElement>('summary');
    const links = menu.querySelectorAll<HTMLAnchorElement>('.mobile-menu-panel a');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let closeTimer: number | undefined;

    const openMenu = () => {
      window.clearTimeout(closeTimer);
      menu.open = true;
      summary?.setAttribute('aria-expanded', 'true');
      // Commit the closed panel state before transitioning it in.
      void menu.offsetWidth;
      menu.classList.add('is-open');
    };

    const closeMenu = () => {
      menu.classList.remove('is-open');
      summary?.setAttribute('aria-expanded', 'false');
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        menu.open = false;
      }, reducedMotion ? 0 : 260);
    };

    summary?.addEventListener('click', (event) => {
      event.preventDefault();
      menu.open && menu.classList.contains('is-open') ? closeMenu() : openMenu();
    });

    links.forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('click', (event) => {
      if (menu.open && !menu.contains(event.target as Node)) closeMenu();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && menu.open) {
        closeMenu();
        summary?.focus();
      }
    });
  });
</script>

<style>
  .site-nav {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    backdrop-filter: blur(20px);
    transition: background-color var(--motion-base) var(--motion-ease-standard);
  }

  .brand-link {
    width: clamp(160px, 14vw, 186px);
    display: inline-flex;
    transition: opacity var(--motion-fast) ease, transform var(--motion-base) var(--motion-ease);
  }
  .brand-link:hover { opacity: .78; transform: translateY(-1px); }
  .brand-link img {
    width: 100%;
    height: auto;
    min-height: 0 !important;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    font-size: 13px;
    font-weight: 760;
  }
  .nav-links a {
    position: relative;
    color: #3B3B3B;
    text-decoration: none;
    transition: color var(--motion-fast) ease;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -7px;
    height: 1px;
    background: #000;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--motion-base) var(--motion-ease);
  }
  .nav-links a:hover {
    color: #000;
  }
  .nav-links a:hover::after,
  .nav-links a:focus-visible::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .mobile-menu {
    display: none;
    position: relative;
  }
  .mobile-menu summary {
    width: 46px;
    height: 46px;
    display: grid;
    place-content: center;
    gap: 5px;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: 999px;
    background: rgba(255,255,255,.72);
    cursor: pointer;
    list-style: none;
    transition:
      background-color var(--motion-fast) ease,
      border-color var(--motion-fast) ease,
      transform var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease);
  }
  .mobile-menu summary:hover {
    border-color: rgba(0,0,0,.24);
    background: rgba(255,255,255,.92);
    box-shadow: 0 10px 28px rgba(0,0,0,.08);
    transform: translateY(-1px);
  }
  .mobile-menu summary::-webkit-details-marker { display: none; }
  .mobile-menu summary span {
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #000;
    display: block;
    transform-origin: center;
    transition: transform var(--motion-base) var(--motion-ease), opacity var(--motion-fast) ease;
  }
  .mobile-menu.is-open summary span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-menu.is-open summary span:nth-child(2) { opacity: 0; transform: scaleX(.35); }
  .mobile-menu.is-open summary span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .mobile-menu-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 12px);
    min-width: 220px;
    padding: 10px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 14px;
    background: rgba(255,255,255,.96);
    box-shadow: 0 24px 60px rgba(0,0,0,.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translate3d(0, -8px, 0) scale(.985);
    transform-origin: top right;
    transition:
      opacity 220ms ease,
      transform 260ms var(--motion-ease),
      visibility 0s linear 260ms;
  }
  .mobile-menu.is-open .mobile-menu-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate3d(0, 0, 0) scale(1);
    transition-delay: 0s;
  }
  .mobile-menu-panel a {
    display: block;
    padding: 13px 14px;
    border-radius: 12px;
    color: #000;
    text-decoration: none;
    font-size: 15px;
    font-weight: 820;
    transition: background-color var(--motion-fast) ease, transform var(--motion-base) var(--motion-ease);
  }
  .mobile-menu-panel a:hover {
    background: rgba(0,0,0,.055);
    transform: translateX(3px);
  }

  @media (max-width: 920px) {
    .nav-links { display: none; }
    .mobile-menu { display: block; }
  }

  @media (max-width: 560px) {
    .site-nav { width: min(100% - 32px, 1180px); }
    .brand-link { width: 154px; }
  }
</style>
