<div class="contact-panel">
  <div class="contact-copy">
    <p class="studio-kicker">/ Start a conversation</p>
    <h2>Build, partner, pilot, or advise.</h2>
    <p>
      Reach out if you are a founder, operator, advisor, early customer, investor, or strategic partner interested in a YONG Venture Studio track.
    </p>
    <a class="btn-secondary" href="https://calendly.com/gary-yong-yongai/30min" target="_blank" rel="noopener">Book on Calendly</a>
  </div>

  <form class="contact-form" id="contactForm" action="https://formspree.io/f/xwvnkpak" method="POST">
    <div class="form-grid">
      <input type="text" name="name" placeholder="Your name" required />
      <input type="email" name="email" placeholder="Work email" required />
    </div>

    <input type="text" name="company" placeholder="Company or venture" />

    <select name="interest" required>
      <option value="" disabled selected>What are you interested in?</option>
      <option value="founder">Founder collaboration</option>
      <option value="pilot">Pilot or early customer</option>
      <option value="operator">Operator insight</option>
      <option value="advisor">Advisor or expert network</option>
      <option value="investor">Investor or strategic partner</option>
      <option value="partner">Commercial partnership</option>
      <option value="other">Something else</option>
    </select>

    <textarea name="message" rows="5" placeholder="Tell us what you are building, where you see an opportunity, or which venture track caught your attention."></textarea>

    <button type="submit" id="submitBtn" class="btn-primary contact-submit">
      <span id="submitText">Send Message</span>
      <svg id="submitIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
      <div id="submitSpinner" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
    </button>

    <p class="form-note">
      Email directly at <a href="mailto:gary.yong@yongai.ca">gary.yong@yongai.ca</a>.
    </p>
  </form>

  <div id="successMessage" class="success-message hidden">
    <h3>Message received.</h3>
    <p>Thanks. I will review it and reply soon.</p>
    <button onclick="resetForm()" class="text-link">Send another message</button>
  </div>
</div>

<script>
  function initContactForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const submitIcon = document.getElementById('submitIcon');
    const submitSpinner = document.getElementById('submitSpinner');
    const successMessage = document.getElementById('successMessage');
    if (!form || !submitBtn || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      submitBtn.disabled = true;
      submitText!.textContent = 'Sending...';
      submitIcon!.classList.add('hidden');
      submitSpinner!.classList.remove('hidden');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' }
        });

        if (!response.ok) throw new Error('Failed');
        form.classList.add('hidden');
        successMessage!.classList.remove('hidden');
      } catch {
        alert('Error sending message. Please email gary.yong@yongai.ca directly.');
        submitBtn.disabled = false;
        submitText!.textContent = 'Send Message';
        submitIcon!.classList.remove('hidden');
        submitSpinner!.classList.add('hidden');
      }
    });
  }

  function resetForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const successMessage = document.getElementById('successMessage');
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const submitIcon = document.getElementById('submitIcon');
    const submitSpinner = document.getElementById('submitSpinner');
    form.reset();
    form.classList.remove('hidden');
    successMessage!.classList.add('hidden');
    submitBtn.disabled = false;
    submitText!.textContent = 'Send Message';
    submitIcon!.classList.remove('hidden');
    submitSpinner!.classList.add('hidden');
  }

  document.addEventListener('DOMContentLoaded', initContactForm);
  document.addEventListener('astro:page-load', initContactForm);
</script>
