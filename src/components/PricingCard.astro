---
export interface Props {
  tier: string;
  title: string;
  price: string;
  term: string;
  description: string;
  features: string[];
  buttonText: string;
  featured?: boolean;
  badgeText?: string;
}

const {
  tier,
  title,
  price,
  term,
  description,
  features,
  buttonText,
  featured = false,
  badgeText = "Most Popular"
} = Astro.props;
---

<div class={`relative bg-white rounded-2xl p-8 h-full flex flex-col border transition-all duration-200 hover:shadow-lg ${
  featured
    ? 'border-[#C2410C]/40 shadow-[0_4px_24px_rgba(194,65,12,0.12)] ring-1 ring-[#C2410C]/20'
    : 'border-[rgba(0,0,0,0.08)] shadow-[0_1px_4px_rgba(0,0,0,0.05)]'
}`}>

  {featured && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#C2410C] text-white text-xs font-bold py-2 px-6 rounded-full uppercase tracking-wider shadow-sm">
      {badgeText}
    </div>
  )}

  <div class="mb-8">
    <div class="text-xs font-bold uppercase tracking-widest text-[#94A3B8] mb-3">{tier}</div>
    <h3 class="text-2xl font-bold text-[#1C1C1E] mb-4">{title}</h3>
    <div class="mb-4">
      <span class="text-4xl font-black text-[#1C1C1E]">{price}</span>
      <span class="text-[#64748B] ml-2 text-sm">{term}</span>
    </div>
    <p class="text-[#64748B] leading-relaxed text-sm">{description}</p>
  </div>

  <ul class="space-y-3 flex-1 mb-8">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-[#C2410C] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-[#64748B] text-sm leading-relaxed">{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href="#contact"
    class={`w-full py-3.5 px-6 rounded-xl font-semibold text-center text-sm transition-all duration-200 ${
      featured
        ? 'bg-[#C2410C] text-white hover:bg-[#9A3408] shadow-sm'
        : 'bg-[#FAFAF8] text-[#1C1C1E] border border-[rgba(0,0,0,0.1)] hover:border-[rgba(194,65,12,0.3)] hover:bg-[#FFF7ED]'
    }`}
  >
    {buttonText}
  </a>
</div>
