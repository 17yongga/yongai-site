---
// Process Timeline — YongAI methodology, light theme

const phases = [
  {
    number: 1,
    title: "Discovery",
    duration: "1 week",
    description: "We map out how your team works and find the biggest time-savers.",
    deliverable: "Clear report showing where AI fits best",
    accentColor: "#C2410C",
    bgColor: "rgba(194,65,12,0.07)",
    borderColor: "rgba(194,65,12,0.2)"
  },
  {
    number: 2,
    title: "Assessment",
    duration: "2 weeks",
    description: "We dig into your processes and build a ranked list of what to automate first, with expected savings.",
    deliverable: "Step-by-step plan with expected savings",
    accentColor: "#2563EB",
    bgColor: "rgba(37,99,235,0.07)",
    borderColor: "rgba(37,99,235,0.2)"
  },
  {
    number: 3,
    title: "Implementation",
    duration: "3–4 weeks",
    description: "We build custom AI tools, test them thoroughly, and connect them to what you already use.",
    deliverable: "Working AI solution, tested and ready to go",
    accentColor: "#059669",
    bgColor: "rgba(5,150,105,0.07)",
    borderColor: "rgba(5,150,105,0.2)"
  },
  {
    number: 4,
    title: "Optimization",
    duration: "Ongoing",
    description: "We keep watching, tweaking, and improving to make sure things keep working well.",
    deliverable: "Monthly report showing results",
    accentColor: "#B45309",
    bgColor: "rgba(180,83,9,0.07)",
    borderColor: "rgba(180,83,9,0.2)"
  }
];
---

<!-- Horizontal step indicators -->
<div class="flex items-center max-w-4xl mx-auto mb-12 px-4">
  {phases.map((phase, i) => (
    <>
      <div class="flex flex-col items-center">
        <div
          class="w-10 h-10 rounded-full flex items-center justify-center font-black text-sm text-white shadow-sm"
          style={`background: ${phase.accentColor};`}
        >
          {phase.number}
        </div>
        <span class="text-xs font-semibold text-[#64748B] mt-2 whitespace-nowrap hidden sm:block">{phase.title}</span>
      </div>
      {i < phases.length - 1 && (
        <div class="flex-1 h-px bg-[rgba(0,0,0,0.1)] mx-3 mt-[-16px] sm:mt-[-16px]"></div>
      )}
    </>
  ))}
</div>

<!-- Phase cards -->
<div class="grid grid-cols-1 lg:grid-cols-4 gap-5">
  {phases.map((phase) => (
    <div
      class="bg-white rounded-xl p-6 border shadow-sm hover:shadow-md transition-shadow duration-200"
      style={`border-color: ${phase.borderColor}; border-left: 3px solid ${phase.accentColor};`}
    >
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-[#1C1C1E] text-base">Phase {phase.number}: {phase.title}</h3>
        <span
          class="text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap"
          style={`background: ${phase.bgColor}; color: ${phase.accentColor};`}
        >
          {phase.duration}
        </span>
      </div>

      <p class="text-[#64748B] text-sm leading-relaxed mb-5">
        {phase.description}
      </p>

      <div
        class="rounded-lg p-3 border text-xs"
        style={`background: ${phase.bgColor}; border-color: ${phase.borderColor};`}
      >
        <span class="font-semibold block mb-0.5" style={`color: ${phase.accentColor};`}>Deliverable:</span>
        <span class="text-[#64748B]">{phase.deliverable}</span>
      </div>
    </div>
  ))}
</div>
