---
export interface Props {
  isDemoPage?: boolean;
}

const { isDemoPage = false } = Astro.props;
const base = isDemoPage ? "/" : "";
---

<nav class="fixed top-0 left-0 right-0 h-16 z-50 navbar" id="nav">
  <div class="studio-shell h-full">
    <div class="flex items-center justify-between h-full">
      <a href={isDemoPage ? "/" : "#top"} class="flex items-center gap-2.5 group" aria-label="YongAI home">
        <img src="/brand/v3/YongAI_horizontal_black_transparent.svg" alt="YongAI" class="h-9 w-auto" />
      </a>

      <ul class="hidden md:flex items-center gap-8">
        <li><a href={`${base}#ventures`} class="nav-link">Portfolio</a></li>
        <li><a href={`${base}#studio-system`} class="nav-link">How We Work</a></li>
        <li><a href={`${base}#contact`} class="nav-link">Contact</a></li>
        <li><a href="/responsible-ai" class="nav-link">Trust</a></li>
        <li>
          <a href={`${base}#contact`} class="nav-cta">
            Let's Build
          </a>
        </li>
      </ul>

      <button class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer" id="burger" aria-label="Toggle menu">
        <span class="w-5 h-0.5 bg-[#000000] transition-all duration-300 block"></span>
        <span class="w-5 h-0.5 bg-[#000000] transition-all duration-300 block"></span>
        <span class="w-5 h-0.5 bg-[#000000] transition-all duration-300 block"></span>
      </button>
    </div>

    <div class="hidden md:hidden absolute top-full left-0 right-0 bg-[#FAF8F2] border-b border-[rgba(0,0,0,0.08)] shadow-md p-6" id="mobileMenu">
      <ul class="flex flex-col gap-4">
        <li><a href={`${base}#ventures`} class="mobile-link">Portfolio</a></li>
        <li><a href={`${base}#studio-system`} class="mobile-link">How We Work</a></li>
        <li><a href={`${base}#contact`} class="mobile-link">Contact</a></li>
        <li><a href="/responsible-ai" class="mobile-link">Trust</a></li>
        <li>
          <a href={`${base}#contact`} class="nav-cta w-full justify-center">
            Let's Build
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  function initMobileMenu() {
    const burger = document.getElementById('burger');
    const mobileMenu = document.getElementById('mobileMenu');
    const nav = document.getElementById('nav');
    if (!burger || !mobileMenu || !nav) return;

    burger.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      const spans = burger.querySelectorAll('span');
      const open = !mobileMenu.classList.contains('hidden');
      spans[0].style.transform = open ? 'rotate(45deg) translateY(7px)' : '';
      spans[1].style.opacity = open ? '0' : '';
      spans[2].style.transform = open ? 'rotate(-45deg) translateY(-7px)' : '';
    });

    document.addEventListener('click', (event) => {
      if (!nav.contains(event.target as Node)) {
        mobileMenu.classList.add('hidden');
      }
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        nav.classList.add('scrolled');
        nav.style.background = 'rgba(248, 246, 240, 0.9)';
        nav.style.backdropFilter = 'blur(14px)';
        nav.style.borderBottom = '1px solid rgba(0, 0, 0, 0.08)';
      } else {
        nav.classList.remove('scrolled');
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.borderBottom = 'none';
      }
    }, { passive: true });
  }

  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
